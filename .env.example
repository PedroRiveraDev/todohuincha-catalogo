# =============================================================================
# Todo Huincha — public env contract (catalog-v2-ui-migration-slice-1)
# Copy to .env and fill in. .env is gitignored.
# Placeholders below are EXAMPLES only — do not commit real values.
# =============================================================================

# Public origin URL for the site. Used by share links, OG tags, canonical URLs.
# Local dev: http://localhost:4322
# Production: https://todohuincha.cl
PUBLIC_SITE_URL=http://localhost:4322

# Comma-separated key:value pairs of WhatsApp contact numbers.
# Format: <key>:<E.164-number>,<key>:<E.164-number>,...
# Leave empty in this example; replace with real values in your local .env.
# Example (placeholders only — replace with real values in your local .env):
# PUBLIC_WHATSAPP_NUMBERS=sales:+56912345678,repuestos:+56912345679,machinery:+56912345680
PUBLIC_WHATSAPP_NUMBERS=

# Optional: Google Analytics 4 measurement ID. Uncomment to enable.
# PUBLIC_GA_ID=

# -----------------------------------------------------------------------------
# Backend source (mockup vs .NET 10)
# -----------------------------------------------------------------------------
# While the C# .NET 10 backend is being built by another team, leave these
# EMPTY so the Astro adapter reads from the local files:
#   - docs/catalogo_productos_robusto_completo_corregido.json (catalog)
#   - docs/catalogo_productos_schema_validacion_corregido.json (schema)
# and the PDF buttons use client-side jsPDF.
#
# When .NET 10 ships the catalog + PDF endpoints, set BOTH variables to the
# same base URL and the frontend will switch without any code change.
#
# Format examples (placeholder values, do not commit real ones):
#   PUBLIC_CATALOG_BASE_URL=https://api.todohuincha.cl
#   PUBLIC_PDF_BASE_URL=https://api.todohuincha.cl/generate
#
# PDF generation endpoints consumed when PUBLIC_PDF_BASE_URL is set:
#   - {PUBLIC_PDF_BASE_URL}/full-catalog-pdf
#   - {PUBLIC_PDF_BASE_URL}/category-catalog-pdf?category=<slug>
#   - {PUBLIC_PDF_BASE_URL}/machinery-technical-sheet-pdf?sku=<sku>
#   - {PUBLIC_PDF_BASE_URL}/service-sheet-pdf?service_code=<code>
#   - {PUBLIC_PDF_BASE_URL}/simple-product-card-pdf?sku=<sku>
#
# While empty: local JSON + client-side jsPDF (current mockup behavior).
PUBLIC_CATALOG_BASE_URL=
PUBLIC_PDF_BASE_URL=
