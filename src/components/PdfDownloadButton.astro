---
// src/components/PdfDownloadButton.astro
// Catalog PDF generator with 3 density-based templates (denso/medio/compacto)
// and cover/back covers using images provided by the user.
//
// Pipeline:
//   1. Two full-bleed cover pages (cover-1.png, cover-2.png)
//   2. For each category: banner + title + description + items grouped by density
//   3. One full-bleed back cover (back-cover.png)
//
// Image fallback chain (per item):
//   - item.assets.main_image  (data_base64 or url)
//   - item.assets.gallery[i]
//   - category.assets.banner.url
//   - /catalog/placeholder.svg  (brand logo, drawn inline)
//
// Driven by PdfOptions (popup-confirmed) with skip-if-saved behaviour.
//
// Refs:
//   docs/INVENTARIO_CATEGORIAS.md
//   docs/catalogo_productos_schema_validacion_corregido.json
//   openspec/changes/pdf-catalog-v2/spec.md

interface Props {
  title: string;
  subtitle: string;
  rows: string[];
}

const { title, subtitle, rows } = Astro.props;
---

<button
  class="pdf-btn-dark"
  id="cat-pdf-btn"
  type="button"
  data-title={title}
  data-subtitle={subtitle}
  data-rows={JSON.stringify(rows)}
  data-pdf-trigger
>
  <svg class="download-icon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
  Generar Catalogo
</button>

<script>
  import { jsPDF } from 'jspdf';
  import { classifyDensity, hasImage } from '../lib/pdf-types.ts';

  const pdfBtn = document.querySelector<HTMLButtonElement>('[data-pdf-trigger]');
  if (!pdfBtn) {
    // No-op: button is not on the page (defensive guard).
  } else {
    // -------------------------------------------------------------------
    // Constants and palette
    // -------------------------------------------------------------------

    const ORANGE: [number, number, number] = [251, 77, 8];
    const SLATE: [number, number, number] = [49, 62, 72];
    const MUTED: [number, number, number] = [108, 107, 101];
    const LINE: [number, number, number] = [234, 223, 216];
    const CREAM: [number, number, number] = [255, 250, 247];
    const A4_W = 210;
    const A4_H = 297;
    const MARGIN_X = 15;
    const CONTENT_W = A4_W - 2 * MARGIN_X;

    const PLACEHOLDER_PATH = '/catalog/placeholder.svg';

    // -------------------------------------------------------------------
    // Catalog payload (read from window.__CATALOG_PAYLOAD__)
    // -------------------------------------------------------------------

    interface PdfMachineryProfile {
      model?: string | null;
      brand?: string | null;
      short_description?: string | null;
      long_description?: string | null;
      features?: string[] | null;
      specification_groups?: Array<{
        group_code?: string;
        label?: string;
        values?: Array<{
          label?: string;
          value_text?: string | null;
          value_number?: number | null;
          unit?: string | null;
        }>;
      }> | null;
      price_observations?: unknown[] | null;
    }
    interface PdfItem {
      sku?: string;
      display_name?: string;
      item_type?: string;
      category_code?: string;
      category_label?: string;
      category_group?: string;
      machinery_profile?: PdfMachineryProfile | null;
      pricing?: { sale_amount?: number | null; currency?: string; formatted?: string; is_price_available?: boolean };
      assets?: {
        main_image?: { url?: string | null; data_base64?: string | null } | null;
        gallery?: Array<{ url?: string | null; data_base64?: string | null }>;
      };
    }
    interface PdfCategory {
      label?: string;
      slug?: string;
      group?: string;
      description?: string | null;
      assets?: {
        banner?: { url?: string | null } | null;
        background?: { url?: string | null } | null;
      };
    }
    interface PdfCatalogPayload {
      items?: PdfItem[];
      categories?: PdfCategory[];
      catalog_assets?: {
        cover_image_1?: { url?: string | null };
        cover_image_2?: { url?: string | null };
        back_cover?: { url?: string | null };
        placeholder_image?: { url?: string | null };
        logo?: { url?: string | null };
      };
    }
    interface PdfOptions {
      incluirPortada: boolean;
      incluirContraportada: boolean;
    }

    const PDF_OPTIONS_KEY = 'cat:pdf:options';
    const PDF_OPEN_EVENT = 'pdf:options-open';
    const PDF_CONFIRMED_EVENT = 'pdf:options-confirmed';

    function defaultOptions(): PdfOptions {
      return { incluirPortada: true, incluirContraportada: true };
    }

    function loadOptions(): PdfOptions | null {
      try {
        const raw = localStorage.getItem(PDF_OPTIONS_KEY);
        if (!raw) return null;
        const parsed = JSON.parse(raw) as Partial<PdfOptions>;
        if (typeof parsed !== 'object' || parsed === null) return null;
        return {
          incluirPortada: parsed.incluirPortada === true,
          incluirContraportada: parsed.incluirContraportada === true,
        };
      } catch {
        return null;
      }
    }

    // -------------------------------------------------------------------
    // Image loading
    // -------------------------------------------------------------------

    async function urlToBase64(url: string): Promise<string | null> {
      if (typeof document === 'undefined' || typeof Image === 'undefined') return null;
      try {
        const img = new Image();
        img.crossOrigin = 'anonymous';
        img.src = url;
        await new Promise<void>((resolve, reject) => {
          img.onload = () => resolve();
          img.onerror = () => reject(new Error(`image load failed: ${url}`));
        });
        const canvas = document.createElement('canvas');
        canvas.width = img.naturalWidth || 600;
        canvas.height = img.naturalHeight || 600;
        const ctx = canvas.getContext('2d');
        if (!ctx) return null;
        ctx.drawImage(img, 0, 0);
        return canvas.toDataURL('image/jpeg', 0.85);
      } catch {
        return null;
      }
    }

    function dataBase64ToJpeg(b64: string): string | null {
      if (!b64) return null;
      if (b64.startsWith('data:image/')) return b64;
      return `data:image/png;base64,${b64}`;
    }

    /**
     * Resolve the best image for an item. Returns a base64 JPEG/PNG string
     * ready to be passed to jsPDF.addImage, or null if nothing usable exists.
     */
    async function resolveItemImage(item: PdfItem, category: PdfCategory | undefined): Promise<string | null> {
      // 1. main_image data_base64
      const main = item.assets?.main_image;
      if (main?.data_base64) {
        const asJpeg = dataBase64ToJpeg(main.data_base64);
        if (asJpeg) return asJpeg;
      }
      // 2. main_image url
      if (main?.url) {
        const b64 = await urlToBase64(main.url);
        if (b64) return b64;
      }
      // 3. gallery[0]
      const gallery = item.assets?.gallery ?? [];
      for (const g of gallery) {
        if (g.data_base64) {
          const asJpeg = dataBase64ToJpeg(g.data_base64);
          if (asJpeg) return asJpeg;
        }
        if (g.url) {
          const b64 = await urlToBase64(g.url);
          if (b64) return b64;
        }
      }
      // 4. category banner
      if (category?.assets?.banner?.url) {
        const b64 = await urlToBase64(category.assets.banner.url);
        if (b64) return b64;
      }
      // 5. placeholder (always present, never throws)
      return await urlToBase64(PLACEHOLDER_PATH);
    }

    async function loadAssetImage(url: string | null | undefined): Promise<string | null> {
      if (!url) return null;
      return await urlToBase64(url);
    }

    // -------------------------------------------------------------------
    // Drawing helpers
    // -------------------------------------------------------------------

    let pageNum = 1;

    function addFullBleedPage(pdf: jsPDF, imageBase64: string | null): void {
      pdf.addPage();
      pageNum++;
      if (imageBase64) {
        try {
          pdf.addImage(imageBase64, 'JPEG', 0, 0, A4_W, A4_H);
        } catch {
          // Fallback: orange page with logo vector
          pdf.setFillColor(ORANGE[0], ORANGE[1], ORANGE[2]);
          pdf.rect(0, 0, A4_W, A4_H, 'F');
        }
      } else {
        pdf.setFillColor(ORANGE[0], ORANGE[1], ORANGE[2]);
        pdf.rect(0, 0, A4_W, A4_H, 'F');
        pdf.setTextColor(255, 255, 255);
        pdf.setFont('helvetica', 'bold');
        pdf.setFontSize(28);
        pdf.text('TODO HUINCHA', A4_W / 2, A4_H / 2, { align: 'center' });
      }
    }

    function drawHeaderBand(pdf: jsPDF, text: string): number {
      pdf.setFillColor(ORANGE[0], ORANGE[1], ORANGE[2]);
      pdf.rect(MARGIN_X, 8, CONTENT_W, 10, 'F');
      pdf.setTextColor(255, 255, 255);
      pdf.setFont('helvetica', 'bold');
      pdf.setFontSize(11);
      pdf.text(text.toUpperCase(), MARGIN_X + 4, 15);
      pdf.setTextColor(MUTED[0], MUTED[1], MUTED[2]);
      pdf.setFont('helvetica', 'normal');
      pdf.setFontSize(8);
      pdf.text(`Pagina ${pageNum}`, MARGIN_X + CONTENT_W - 2, 15, { align: 'right' });
      return 24;
    }

    function drawFooter(pdf: jsPDF): void {
      pdf.setDrawColor(LINE[0], LINE[1], LINE[2]);
      pdf.setLineWidth(0.3);
      pdf.line(MARGIN_X, A4_H - 14, MARGIN_X + CONTENT_W, A4_H - 14);
      pdf.setTextColor(MUTED[0], MUTED[1], MUTED[2]);
      pdf.setFont('helvetica', 'normal');
      pdf.setFontSize(7);
      pdf.text(
        'Comercializadora Todo Huincha Ltda. - Longitudinal Sur 4277, Padre Las Casas - (45) 240 0000 - info@todohuincha.com',
        A4_W / 2,
        A4_H - 10,
        { align: 'center' }
      );
    }

    function ensureRoom(pdf: jsPDF, currentY: number, needed: number): number {
      if (currentY + needed <= A4_H - 18) return currentY;
      drawFooter(pdf);
      pdf.addPage();
      pageNum++;
      return drawHeaderBand(pdf, 'Continuacion');
    }

    function drawCategoryBanner(pdf: jsPDF, bannerBase64: string | null, label: string, y: number): number {
      const bandH = 28;
      if (bannerBase64) {
        try {
          pdf.addImage(bannerBase64, 'JPEG', MARGIN_X, y, CONTENT_W, bandH);
        } catch {
          drawOrangeBand(pdf, label, y, bandH);
        }
      } else {
        drawOrangeBand(pdf, label, y, bandH);
      }
      return y + bandH + 4;
    }

    function drawOrangeBand(pdf: jsPDF, text: string, y: number, h: number): void {
      pdf.setFillColor(ORANGE[0], ORANGE[1], ORANGE[2]);
      pdf.rect(MARGIN_X, y, CONTENT_W, h, 'F');
      pdf.setTextColor(255, 255, 255);
      pdf.setFont('helvetica', 'bold');
      pdf.setFontSize(16);
      pdf.text(text.toUpperCase(), MARGIN_X + 4, y + h / 2 + 5);
    }

    function drawCategoryTitle(pdf: jsPDF, label: string, y: number): number {
      pdf.setTextColor(SLATE[0], SLATE[1], SLATE[2]);
      pdf.setFont('helvetica', 'bold');
      pdf.setFontSize(18);
      pdf.text(label, MARGIN_X, y);
      return y + 7;
    }

    function drawCategoryDescription(pdf: jsPDF, description: string | null | undefined, y: number): number {
      if (!description) return y;
      pdf.setTextColor(MUTED[0], MUTED[1], MUTED[2]);
      pdf.setFont('helvetica', 'normal');
      pdf.setFontSize(9.5);
      const lines = pdf.splitTextToSize(description, CONTENT_W);
      const maxLines = Math.min(lines.length, 4);
      for (let i = 0; i < maxLines; i++) {
        pdf.text(lines[i], MARGIN_X, y + i * 4.2);
      }
      return y + maxLines * 4.2 + 3;
    }

    function drawPriceLine(pdf: jsPDF, item: PdfItem, y: number): number {
      const p = item.pricing;
      let label = 'A cotizar';
      if (p?.is_price_available && typeof p?.sale_amount === 'number' && p.sale_amount > 0) {
        const formatted = p.sale_amount.toLocaleString('es-CL');
        const currency = (p.currency ?? 'CLP').toUpperCase();
        label = `${currency} $${formatted} (IVA incl.)`;
      }
      pdf.setTextColor(ORANGE[0], ORANGE[1], ORANGE[2]);
      pdf.setFont('helvetica', 'bold');
      pdf.setFontSize(11);
      pdf.text(`Precio: ${label}`, MARGIN_X, y);
      return y + 6;
    }

    function drawBadge(pdf: jsPDF, text: string, x: number, y: number): number {
      const w = 38;
      const h = 9;
      pdf.setFillColor(40, 167, 69); // green
      pdf.roundedRect(x, y, w, h, 1.5, 1.5, 'F');
      pdf.setTextColor(255, 255, 255);
      pdf.setFont('helvetica', 'bold');
      pdf.setFontSize(9);
      pdf.text(text, x + w / 2, y + h / 2 + 3, { align: 'center' });
      return x + w + 4;
    }

    // -------------------------------------------------------------------
    // Spec cleanup: trim next-group leakage and word-wrap long values
    // -------------------------------------------------------------------

    function cleanSpecValue(valueText: string | null | undefined): string {
      if (!valueText) return '';
      const parts = valueText.split(
        /\s+(?=(?:MOTOR|EJE|MESA(?:\s+DESLIZANTE)?|MESA(?:\s+EXTENSIBLE)?|VELOCIDAD|TAMAÑO\s+DE\s+LA\s+CERCA|TAMANO\s+DE\s+LA\s+CERCA|DIMENSIONES|PESO|CAPACIDAD|GUIA|GUÍA|CABEZAL)\s*:)/i
      );
      return (parts[0] ?? '').replace(/\s+/g, ' ').trim();
    }

    // -------------------------------------------------------------------
    // Template DENSO: machinery sheet (TUPI 3HP-style)
    // -------------------------------------------------------------------

    async function renderDenso(
      pdf: jsPDF,
      item: PdfItem,
      imageBase64: string | null,
      category: PdfCategory | undefined,
      y: number
    ): Promise<number> {
      const profile = item.machinery_profile;
      const brand = (profile?.brand ?? item.category_label ?? '').toString().toUpperCase();
      const model = profile?.model ?? null;
      const displayName = (item.display_name ?? '').replace(/[\s\-–—]+$/, '').trim();

      y = ensureRoom(pdf, y, 70);

      // 2-column header: photo on the left, text on the right
      const photoX = MARGIN_X;
      const photoY = y;
      const photoW = 60;
      const photoH = 45;
      if (imageBase64) {
        try {
          pdf.addImage(imageBase64, 'JPEG', photoX, photoY, photoW, photoH);
        } catch {
          pdf.setFillColor(CREAM[0], CREAM[1], CREAM[2]);
          pdf.rect(photoX, photoY, photoW, photoH, 'F');
        }
      } else {
        pdf.setFillColor(CREAM[0], CREAM[1], CREAM[2]);
        pdf.rect(photoX, photoY, photoW, photoH, 'F');
      }
      const textX = photoX + photoW + 6;
      const textW = CONTENT_W - photoW - 6;

      let textY = y + 7;
      if (brand) {
        pdf.setTextColor(ORANGE[0], ORANGE[1], ORANGE[2]);
        pdf.setFont('helvetica', 'bold');
        pdf.setFontSize(10);
        pdf.text(brand, textX, textY);
        textY += 5;
      }
      if (model) {
        pdf.setTextColor(MUTED[0], MUTED[1], MUTED[2]);
        pdf.setFont('helvetica', 'normal');
        pdf.setFontSize(8);
        pdf.text(`Modelo: ${model}`, textX, textY);
        textY += 4;
      }
      pdf.setTextColor(SLATE[0], SLATE[1], SLATE[2]);
      pdf.setFont('helvetica', 'bold');
      pdf.setFontSize(13);
      const nameLines = pdf.splitTextToSize(displayName, textW);
      pdf.text(nameLines, textX, textY);
      textY += nameLines.length * 5.2 + 1.5;
      const desc = profile?.short_description ?? null;
      if (desc) {
        pdf.setTextColor(MUTED[0], MUTED[1], MUTED[2]);
        pdf.setFont('helvetica', 'italic');
        pdf.setFontSize(8.5);
        const descLines = pdf.splitTextToSize(desc, textW).slice(0, 2);
        pdf.text(descLines, textX, textY);
        textY += descLines.length * 4 + 1;
      }
      drawBadge(pdf, 'DISPONIBLE', textX, textY);
      y = Math.max(y + photoH + 4, textY + 6);

      // Features bullets (cap 6)
      const features = (profile?.features ?? []).slice(0, 6);
      if (features.length > 0) {
        y = ensureRoom(pdf, y, features.length * 4.5 + 6);
        pdf.setTextColor(SLATE[0], SLATE[1], SLATE[2]);
        pdf.setFont('helvetica', 'bold');
        pdf.setFontSize(10);
        pdf.text('Caracteristicas', MARGIN_X, y);
        y += 5;
        pdf.setTextColor(50, 50, 50);
        pdf.setFont('helvetica', 'normal');
        pdf.setFontSize(9);
        for (const feat of features) {
          const lines = pdf.splitTextToSize('* ' + feat, CONTENT_W - 6);
          y = ensureRoom(pdf, y, lines.length * 4.5 + 1);
          pdf.text(lines, MARGIN_X + 3, y);
          y += lines.length * 4.5 + 1;
        }
        y += 2;
      }

      // Spec groups in 3-column grid (TUPI-style)
      const groups = profile?.specification_groups ?? [];
      if (groups.length > 0) {
        y = ensureRoom(pdf, y, 20);
        pdf.setTextColor(SLATE[0], SLATE[1], SLATE[2]);
        pdf.setFont('helvetica', 'bold');
        pdf.setFontSize(11);
        pdf.text('Especificaciones tecnicas', MARGIN_X, y);
        y += 6;

        // Flatten all values, group into rows of 3 columns
        const cells: { label: string; value: string }[] = [];
        for (const g of groups) {
          const label = (g.label ?? g.group_code ?? '').toString();
          for (const v of g.values ?? []) {
            cells.push({ label: `${label}: ${v.label ?? ''}`, value: cleanSpecValue(v.value_text) });
          }
        }

        const cellW = (CONTENT_W - 4) / 3;
        const rowH = 12;
        const cellsPerRow = 3;
        for (let i = 0; i < cells.length; i += cellsPerRow) {
          y = ensureRoom(pdf, y, rowH + 1);
          // Header band for the row
          pdf.setFillColor(ORANGE[0], ORANGE[1], ORANGE[2]);
          pdf.rect(MARGIN_X, y, CONTENT_W, 5, 'F');
          for (let c = 0; c < cellsPerRow && i + c < cells.length; c++) {
            const cell = cells[i + c];
            pdf.setTextColor(255, 255, 255);
            pdf.setFont('helvetica', 'bold');
            pdf.setFontSize(7.5);
            pdf.text(cell.label.toUpperCase(), MARGIN_X + 2 + c * cellW, y + 3.5, {
              maxWidth: cellW - 4,
            });
          }
          y += 5;
          // Value row
          pdf.setFillColor(CREAM[0], CREAM[1], CREAM[2]);
          pdf.rect(MARGIN_X, y, CONTENT_W, rowH - 5, 'F');
          for (let c = 0; c < cellsPerRow && i + c < cells.length; c++) {
            const cell = cells[i + c];
            pdf.setTextColor(40, 40, 40);
            pdf.setFont('helvetica', 'normal');
            pdf.setFontSize(8);
            const valueLines = pdf.splitTextToSize(cell.value, cellW - 4);
            for (let lineIdx = 0; lineIdx < Math.min(valueLines.length, 2); lineIdx++) {
              pdf.text(valueLines[lineIdx], MARGIN_X + 2 + c * cellW, y + 4 + lineIdx * 3.6);
            }
          }
          y += rowH - 5;
        }
      }

      y = ensureRoom(pdf, y, 6);
      y = drawPriceLine(pdf, item, y);
      return y + 4;
    }

    // -------------------------------------------------------------------
    // Template MEDIO: card with bullet list (MOTOCULTIVADOR-style)
    // -------------------------------------------------------------------

    async function renderMedio(
      pdf: jsPDF,
      item: PdfItem,
      imageBase64: string | null,
      y: number
    ): Promise<number> {
      const profile = item.machinery_profile;
      const displayName = (item.display_name ?? '').replace(/[\s\-–—]+$/, '').trim();
      const brand = (profile?.brand ?? item.category_label ?? '').toString().toUpperCase();

      y = ensureRoom(pdf, y, 55);

      // Photo + text side by side
      const photoW = 55;
      const photoH = 42;
      if (imageBase64) {
        try {
          pdf.addImage(imageBase64, 'JPEG', MARGIN_X, y, photoW, photoH);
        } catch {
          pdf.setFillColor(CREAM[0], CREAM[1], CREAM[2]);
          pdf.rect(MARGIN_X, y, photoW, photoH, 'F');
        }
      } else {
        pdf.setFillColor(CREAM[0], CREAM[1], CREAM[2]);
        pdf.rect(MARGIN_X, y, photoW, photoH, 'F');
      }
      const textX = MARGIN_X + photoW + 5;
      const textW = CONTENT_W - photoW - 5;

      let textY = y + 5;
      pdf.setTextColor(ORANGE[0], ORANGE[1], ORANGE[2]);
      pdf.setFont('helvetica', 'bold');
      pdf.setFontSize(11);
      const titleLines = pdf.splitTextToSize(displayName.toUpperCase(), textW);
      pdf.text(titleLines, textX, textY);
      textY += titleLines.length * 5 + 1;
      if (brand) {
        pdf.setTextColor(MUTED[0], MUTED[1], MUTED[2]);
        pdf.setFont('helvetica', 'normal');
        pdf.setFontSize(8);
        pdf.text(brand, textX, textY);
        textY += 4;
      }
      const model = profile?.model ?? null;
      if (model) {
        pdf.setTextColor(MUTED[0], MUTED[1], MUTED[2]);
        pdf.setFont('helvetica', 'normal');
        pdf.setFontSize(8);
        pdf.text(`Modelo: ${model}`, textX, textY);
      }
      y = Math.max(y + photoH + 4, textY + 6);

      // Inline spec bullets (cap 6)
      const groups = profile?.specification_groups ?? [];
      const features = profile?.features ?? [];
      const bullets: string[] = [];
      for (const f of features.slice(0, 6)) bullets.push(f);
      for (const g of groups.slice(0, 3)) {
        for (const v of (g.values ?? []).slice(0, 2)) {
          bullets.push(`${g.label ?? g.group_code}: ${v.label ?? ''} ${cleanSpecValue(v.value_text)}`.trim());
          if (bullets.length >= 8) break;
        }
        if (bullets.length >= 8) break;
      }
      if (bullets.length > 0) {
        y = ensureRoom(pdf, y, bullets.length * 4 + 4);
        pdf.setTextColor(50, 50, 50);
        pdf.setFont('helvetica', 'normal');
        pdf.setFontSize(9);
        for (const b of bullets) {
          const lines = pdf.splitTextToSize('* ' + b, CONTENT_W - 6);
          y = ensureRoom(pdf, y, lines.length * 4 + 1);
          pdf.text(lines, MARGIN_X + 3, y);
          y += lines.length * 4 + 1;
        }
        y += 2;
      }

      y = ensureRoom(pdf, y, 6);
      y = drawPriceLine(pdf, item, y);
      return y + 2;
    }

    // -------------------------------------------------------------------
    // Template COMPACTO: flat grouped table (CUCHILLO INDUSTRIAL-style)
    // -------------------------------------------------------------------

    function renderCompacto(
      pdf: jsPDF,
      item: PdfItem,
      y: number
    ): number {
      const sku = item.sku ?? '';
      const name = (item.display_name ?? '').replace(/[\s\-–—]+$/, '').trim();

      y = ensureRoom(pdf, y, 7);
      // Zebra striping
      if (pageNum % 2 === 0) {
        pdf.setFillColor(CREAM[0], CREAM[1], CREAM[2]);
        pdf.rect(MARGIN_X, y - 4, CONTENT_W, 7, 'F');
      }
      pdf.setDrawColor(LINE[0], LINE[1], LINE[2]);
      pdf.setLineWidth(0.15);
      pdf.line(MARGIN_X, y + 3, MARGIN_X + CONTENT_W, y + 3);

      pdf.setTextColor(SLATE[0], SLATE[1], SLATE[2]);
      pdf.setFont('helvetica', 'bold');
      pdf.setFontSize(8.5);
      pdf.text(sku, MARGIN_X + 2, y);
      pdf.setTextColor(30, 30, 30);
      pdf.setFont('helvetica', 'normal');
      const nameLines = pdf.splitTextToSize(name, 110);
      pdf.text(nameLines[0] ?? name, MARGIN_X + 25, y);

      // Price on the right
      const p = item.pricing;
      let priceText = 'A cotizar';
      if (p?.is_price_available && typeof p?.sale_amount === 'number' && p.sale_amount > 0) {
        priceText = `${(p.currency ?? 'CLP').toUpperCase()} $${p.sale_amount.toLocaleString('es-CL')}`;
      }
      pdf.setTextColor(ORANGE[0], ORANGE[1], ORANGE[2]);
      pdf.setFont('helvetica', 'bold');
      pdf.text(priceText, MARGIN_X + CONTENT_W - 2, y, { align: 'right' });

      return y + 5;
    }

    // -------------------------------------------------------------------
    // Pre-resolve images in parallel (faster sequential generation)
    // -------------------------------------------------------------------

    async function preResolveImages(
      items: PdfItem[],
      categoriesByLabel: Map<string, PdfCategory>
    ): Promise<Map<string, string | null>> {
      const cache = new Map<string, string | null>();
      const tasks: Promise<void>[] = [];
      for (const item of items) {
        if (!item.sku) continue;
        if (cache.has(item.sku)) continue;
        const cat = item.category_label ? categoriesByLabel.get(item.category_label) : undefined;
        tasks.push(
          resolveItemImage(item, cat).then((b64) => {
            cache.set(item.sku!, b64);
          })
        );
      }
      await Promise.all(tasks);
      return cache;
    }

    // -------------------------------------------------------------------
    // Main generator
    // -------------------------------------------------------------------

    async function generatePDF(opts: PdfOptions): Promise<void> {
      const docTitle = pdfBtn?.dataset.title ?? title;
      const payload = (window as any).__CATALOG_PAYLOAD__ as PdfCatalogPayload | undefined;
      if (!payload || !Array.isArray(payload.items)) {
        console.error('catalog payload missing; aborting PDF generation');
        return;
      }
      const items: PdfItem[] = payload.items;
      const categories: PdfCategory[] = payload.categories ?? [];
      const categoriesByLabel = new Map<string, PdfCategory>();
      for (const c of categories) if (c.label) categoriesByLabel.set(c.label, c);

      // Group items by category label (preserve payload order).
      const byCategory = new Map<string, PdfItem[]>();
      for (const it of items) {
        const key = it.category_label ?? '__none__';
        const arr = byCategory.get(key) ?? [];
        arr.push(it);
        byCategory.set(key, arr);
      }

      const pdf = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
      pageNum = 1;

      // ---- Cover pages (1: full-bleed cover-1, 2: full-bleed cover-2) ----
      if (opts.incluirPortada) {
        const cover1 = await loadAssetImage(payload.catalog_assets?.cover_image_1?.url);
        addFullBleedPage(pdf, cover1);
        const cover2 = await loadAssetImage(payload.catalog_assets?.cover_image_2?.url);
        addFullBleedPage(pdf, cover2);
      }

      // Pre-resolve all images in parallel.
      const imageCache = await preResolveImages(items, categoriesByLabel);

      // ---- Category sections ----
      for (const [label, catItems] of byCategory.entries()) {
        const cat = categoriesByLabel.get(label);
        const bannerBase64 = await loadAssetImage(cat?.assets?.banner?.url);

        // Page header
        pdf.addPage();
        pageNum++;
        let y = drawHeaderBand(pdf, docTitle);
        y = drawCategoryBanner(pdf, bannerBase64, label, y);
        y = drawCategoryTitle(pdf, label, y + 2);
        y = drawCategoryDescription(pdf, cat?.description, y);
        y += 2;

        // Render each item by density
        for (const item of catItems) {
          const density = classifyDensity(item);
          const image = imageCache.get(item.sku ?? '') ?? null;
          if (density === 'denso') {
            y = await renderDenso(pdf, item, image, cat, y);
          } else if (density === 'medio') {
            y = await renderMedio(pdf, item, image, y);
          } else {
            y = renderCompacto(pdf, item, y);
          }
          y += 2;
        }

        drawFooter(pdf);
      }

      // ---- Back cover ----
      if (opts.incluirContraportada) {
        const back = await loadAssetImage(payload.catalog_assets?.back_cover?.url);
        addFullBleedPage(pdf, back);
      }

      // ---- Filename ----
      const dateSlug = new Date().toISOString().slice(0, 10);
      const stem = docTitle
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '');
      pdf.save(`${stem}-${dateSlug}.pdf`);
    }

    // -------------------------------------------------------------------
    // Click contract: skip-if-saved, else open popup.
    // -------------------------------------------------------------------

    pdfBtn.addEventListener('click', () => {
      const saved = loadOptions();
      if (saved) {
        void generatePDF(saved);
      } else {
        document.dispatchEvent(
          new CustomEvent(PDF_OPEN_EVENT, { detail: { trigger: pdfBtn } })
        );
      }
    });

    document.addEventListener(PDF_CONFIRMED_EVENT, (event) => {
      const ev = event as CustomEvent<PdfOptions>;
      if (!ev.detail) return;
      try {
        localStorage.setItem(PDF_OPTIONS_KEY, JSON.stringify(ev.detail));
      } catch {
        // Ignore quota errors; we can still render.
      }
      void generatePDF(ev.detail);
    });
  }
</script>