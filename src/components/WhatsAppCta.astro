---
// src/components/WhatsAppCta.astro
// Context-aware WhatsApp CTA. Reads PUBLIC_WHATSAPP_NUMBERS at build time,
// picks the right key (sales/repuestos/machinery/general), and renders
// either a wa.me link or a disabled-state fallback. Slice 2.
//
// Refs:
//   openspec/changes/catalog-v2-ui-migration-slice-2/design.md (section 6)

import { parseWhatsAppNumbers, buildWhatsAppUrl } from '../lib/whatsapp.ts';

interface Props {
  context: 'sales' | 'repuestos' | 'machinery' | 'general';
  productName?: string;
  sku?: string;
}

const { context, productName, sku } = Astro.props;

// `import.meta.env.*` is inlined at build time by Astro for static output.
const envValue = import.meta.env.PUBLIC_WHATSAPP_NUMBERS;
const numbers = parseWhatsAppNumbers(
  typeof envValue === 'string' ? envValue : undefined
);
const hasAny = Object.keys(numbers).length > 0;

// Fallback chain: context -> sales -> first available.
const resolvedNumber = hasAny
  ? numbers[context] ?? numbers.sales ?? Object.values(numbers)[0]
  : undefined;

const message =
  context === 'general'
    ? 'Hola, quiero cotizar productos de Todo Huincha.'
    : context === 'repuestos'
      ? `Hola, necesito un repuesto: ${productName || 'repuesto'} (código ${sku || 'N/A'}).`
      : context === 'machinery'
        ? `Hola, quiero cotizar maquinaria: ${productName || 'maquinaria'} (código ${sku || 'N/A'}).`
        : `Hola, quiero cotizar ${productName || 'productos'} (código ${sku || 'N/A'}).`;

const ctaLabel =
  context === 'repuestos'
    ? 'Solicitar repuesto por WhatsApp'
    : context === 'machinery'
      ? 'Cotizar maquinaria por WhatsApp'
      : 'Cotizar por WhatsApp';
---
{resolvedNumber ? (
  <a
    href={buildWhatsAppUrl(resolvedNumber, message)}
    target="_blank"
    rel="noreferrer noopener"
    class="button whatsapp-cta"
    data-context={context}
    aria-label={ctaLabel}
  >
    <span class="whatsapp-cta-label">{ctaLabel}</span>
    <span class="whatsapp-cta-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.198-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zm-5.42 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.375a9.86 9.86 0 0 1-1.51-5.26c.002-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
      </svg>
    </span>
  </a>
) : (
  <button
    type="button"
    disabled
    aria-disabled="true"
    class="button whatsapp-cta whatsapp-cta--disabled"
    data-context={context}
  >
    Configura PUBLIC_WHATSAPP_NUMBERS en .env
  </button>
)}

<style>
  .whatsapp-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 6px 6px 6px 18px;
    border-radius: 999px;
    background: #25d366;
    color: #fff;
    font-weight: 800;
    font-size: 0.9rem;
    border: 1px solid #25d366;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.08), 0 8px 24px rgba(37, 211, 102, 0.32);
    transition: transform 150ms cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 150ms cubic-bezier(0.16, 1, 0.3, 1),
                background 150ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .whatsapp-cta:hover {
    background: #1ebe5a;
    transform: translateY(-1px);
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.12), 0 12px 28px rgba(37, 211, 102, 0.42);
  }
  .whatsapp-cta:active {
    transform: scale(0.97);
  }
  .whatsapp-cta-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.15);
    color: #fff;
    flex-shrink: 0;
  }
  .whatsapp-cta-icon svg {
    width: 18px;
    height: 18px;
  }
  .whatsapp-cta--disabled {
    background: var(--soft, #fff0e9);
    color: var(--muted, #6c6b65);
    border-color: var(--line, #eadfd8);
    cursor: not-allowed;
    box-shadow: none;
  }
  .whatsapp-cta--disabled:hover {
    background: var(--soft, #fff0e9);
    transform: none;
    box-shadow: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .whatsapp-cta {
      transition: none;
    }
    .whatsapp-cta:hover {
      transform: none;
    }
    .whatsapp-cta:active {
      transform: none;
    }
  }
</style>