---
const { title, subtitle = '', rows = [] } = Astro.props;
---
<button class="button alt download-pdf" data-title={title} data-subtitle={subtitle} data-rows={JSON.stringify(rows)}><svg class="prods-btn-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin-right:8px;vertical-align:middle;display:inline-block;flex-shrink:0;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>Descargar PDF</button>
<script>
import { jsPDF } from 'jspdf';
document.querySelectorAll<HTMLButtonElement>('.download-pdf').forEach((button) => button.addEventListener('click', async () => {
  const title = button.dataset.title ?? 'Todo Huincha';
  const subtitle = button.dataset.subtitle ?? '';
  const rows = JSON.parse(button.dataset.rows ?? '[]');
  
  const orange = [251, 77, 8];
  const slate = [49, 62, 72];
  const muted = [108, 107, 101];
  const borderCol = [234, 223, 216];
  const bgHeader = [244, 246, 248];
  const bgRowAlt = [250, 251, 252];
  
  // Helper to load logo from DOM or fetch it
  const getLogoBase64 = (): Promise<string | null> => {
    return new Promise((resolve) => {
      const logoImg = document.querySelector<HTMLImageElement>('.brand img');
      if (logoImg && logoImg.complete && logoImg.naturalWidth !== 0) {
        try {
          const canvas = document.createElement('canvas');
          canvas.width = logoImg.naturalWidth;
          canvas.height = logoImg.naturalHeight;
          const ctx = canvas.getContext('2d');
          if (ctx) {
            ctx.drawImage(logoImg, 0, 0);
            resolve(canvas.toDataURL('image/png'));
            return;
          }
        } catch (e) {
          console.warn('Failed to extract logo from DOM image, trying fetch...', e);
        }
      }
      
      const img = new Image();
      img.src = '/logo-todohuincha.svg';
      img.crossOrigin = 'anonymous';
      img.onload = () => {
        try {
          const canvas = document.createElement('canvas');
          canvas.width = img.naturalWidth || 324;
          canvas.height = img.naturalHeight || 92;
          const ctx = canvas.getContext('2d');
          if (ctx) {
            ctx.drawImage(img, 0, 0);
            resolve(canvas.toDataURL('image/png'));
          } else {
            resolve(null);
          }
        } catch (e) {
          resolve(null);
        }
      };
      img.onerror = () => resolve(null);
    });
  };

  const logoBase64 = await getLogoBase64();
  
  const pdf = new jsPDF({
    orientation: 'portrait',
    unit: 'mm',
    format: 'a4'
  });
  
  const drawPageDecorations = (pageNum: number) => {
    // Thin top orange bar (uses minimal ink, matches website)
    pdf.setFillColor(orange[0], orange[1], orange[2]);
    pdf.rect(0, 0, 210, 3.5, 'F');
    
    // Draw Logo on the left
    if (logoBase64) {
      pdf.addImage(logoBase64, 'PNG', 15, 8, 36, 10.3);
    } else {
      // Vector fallback logo
      pdf.setDrawColor(orange[0], orange[1], orange[2]);
      pdf.setLineWidth(0.5);
      pdf.circle(20, 13.5, 4);
      pdf.circle(20, 13.5, 1.2);
      for (let angle = 0; angle < 360; angle += 30) {
        const rad = (angle * Math.PI) / 180;
        pdf.line(20 + 4 * Math.cos(rad), 13.5 + 4 * Math.sin(rad), 20 + 5.2 * Math.cos(rad + 0.1), 13.5 + 5.2 * Math.sin(rad + 0.1));
      }
      pdf.setTextColor(slate[0], slate[1], slate[2]);
      pdf.setFont('helvetica', 'bold');
      pdf.setFontSize(14);
      pdf.text('TODO', 27, 13.5);
      pdf.setTextColor(orange[0], orange[1], orange[2]);
      pdf.text('HUINCHA', 41, 13.5);
    }
    
    // Right-aligned header texts
    pdf.setTextColor(slate[0], slate[1], slate[2]);
    pdf.setFont('helvetica', 'bold');
    pdf.setFontSize(9);
    pdf.text('FICHA TÉCNICA DE PRODUCTO', 195, 12.5, { align: 'right' });
    
    pdf.setTextColor(muted[0], muted[1], muted[2]);
    pdf.setFont('helvetica', 'normal');
    pdf.setFontSize(7.5);
    pdf.text(`Fecha: ${new Date().toLocaleDateString('es-CL')}`, 195, 16.5, { align: 'right' });
    
    // Thin separator line
    pdf.setDrawColor(borderCol[0], borderCol[1], borderCol[2]);
    pdf.setLineWidth(0.25);
    pdf.line(15, 22, 195, 22);
    
    // Footer line and contact info
    pdf.line(15, 276, 195, 276);
    pdf.setTextColor(muted[0], muted[1], muted[2]);
    pdf.setFontSize(7.5);
    pdf.text('Comercializadora Todo Huincha Ltda. · Longitudinal Sur 4277, Padre Las Casas · info@todohuincha.com · (45) 240 0000', 105, 281.5, { align: 'center' });
    pdf.text(`Página ${pageNum}`, 195, 281.5, { align: 'right' });
  };
  
  drawPageDecorations(1);
  let y = 30;
  
  // Category Pill Badge
  if (subtitle) {
    const displayCategory = subtitle.replace(/Código:.*Categoría:\s*/, '').replace(/ · .*/, '').replace('Categoría: ', '').trim();
    if (displayCategory) {
      pdf.setFont('helvetica', 'bold');
      pdf.setFontSize(7);
      const badgeText = displayCategory.toUpperCase();
      const textWidth = pdf.getTextWidth(badgeText);
      
      pdf.setFillColor(255, 240, 233);
      pdf.setDrawColor(255, 197, 175);
      pdf.setLineWidth(0.15);
      pdf.rect(15, y, textWidth + 6, 5, 'FD');
      
      pdf.setTextColor(orange[0], orange[1], orange[2]);
      pdf.text(badgeText, 18, y + 3.7);
      y += 12;
    }
  }
  
  // Product Title (with line wrap)
  pdf.setTextColor(slate[0], slate[1], slate[2]);
  pdf.setFont('helvetica', 'bold');
  pdf.setFontSize(14.5);
  const titleLines = pdf.splitTextToSize(title, 180);
  titleLines.forEach((line: string) => {
    pdf.text(line, 15, y);
    y += 6;
  });
  
  // Internal reference below title
  const codeMatch = subtitle.match(/Código:\s*([^\s·]+)/);
  if (codeMatch && codeMatch[1]) {
    y += 1;
    pdf.setTextColor(muted[0], muted[1], muted[2]);
    pdf.setFont('helvetica', 'normal');
    pdf.setFontSize(8.5);
    pdf.text(`Código interno: ${codeMatch[1]}`, 15, y);
    y += 5.5;
  }
  y += 2.5;
  
  // Table Header Bar
  pdf.setFillColor(bgHeader[0], bgHeader[1], bgHeader[2]);
  pdf.rect(15, y, 180, 8, 'F');
  
  pdf.setFillColor(orange[0], orange[1], orange[2]);
  pdf.rect(15, y, 1.5, 8, 'F');
  
  pdf.setTextColor(slate[0], slate[1], slate[2]);
  pdf.setFont('helvetica', 'bold');
  pdf.setFontSize(8.5);
  pdf.text('ESPECIFICACIONES DEL PRODUCTO', 19, y + 5.5);
  y += 8;
  
  let isAlt = false;
  const metadataRows = rows.filter((r: string) => r.includes(':'));
  const descriptionRows = rows.filter((r: string) => !r.includes(':'));
  
  // Specifications Table Rows
  metadataRows.forEach((row: string) => {
    const colonIndex = row.indexOf(':');
    const key = row.substring(0, colonIndex).trim();
    const val = row.substring(colonIndex + 1).trim();
    
    // Row height logic
    pdf.setFont('helvetica', 'normal');
    pdf.setFontSize(8.5);
    const valLines = pdf.splitTextToSize(val, 120);
    const rowHeight = Math.max(8.5, valLines.length * 4.5 + 4);
    
    if (isAlt) {
      pdf.setFillColor(bgRowAlt[0], bgRowAlt[1], bgRowAlt[2]);
      pdf.rect(15, y, 180, rowHeight, 'F');
    }
    
    pdf.setDrawColor(borderCol[0], borderCol[1], borderCol[2]);
    pdf.setLineWidth(0.15);
    pdf.line(15, y + rowHeight, 195, y + rowHeight);
    
    pdf.setTextColor(slate[0], slate[1], slate[2]);
    pdf.setFont('helvetica', 'bold');
    pdf.text(key, 18, y + 5.5);
    
    pdf.setTextColor(30, 30, 30);
    pdf.setFont('helvetica', 'normal');
    let lineY = y + 5.5;
    valLines.forEach((line: string) => {
      pdf.text(line, 65, lineY);
      lineY += 4.5;
    });
    
    y += rowHeight;
    isAlt = !isAlt;
  });
  
  y += 7;
  
  // Description / Note Section (Callout Card)
  descriptionRows.forEach((row: string) => {
    if (row.includes('info@todohuincha.com') || row.includes('Comercializadora')) return;
    
    const descLines = pdf.splitTextToSize(row, 172);
    const cardHeight = descLines.length * 4.8 + 11;
    
    if (y + cardHeight > 255) {
      pdf.addPage();
      drawPageDecorations(2);
      y = 28;
    }
    
    // Shaded card background
    pdf.setFillColor(253, 253, 252);
    pdf.rect(15, y, 180, cardHeight, 'F');
    
    // Left border accent line
    pdf.setFillColor(orange[0], orange[1], orange[2]);
    pdf.rect(15, y, 0.8, cardHeight, 'F');
    
    // Top border and side borders (very subtle)
    pdf.setDrawColor(240, 238, 235);
    pdf.setLineWidth(0.15);
    pdf.line(15, y, 195, y);
    pdf.line(195, y, 195, y + cardHeight);
    pdf.line(15, y + cardHeight, 195, y + cardHeight);
    
    pdf.setTextColor(slate[0], slate[1], slate[2]);
    pdf.setFont('helvetica', 'bold');
    pdf.setFontSize(8);
    pdf.text('INFORMACIÓN DE COTIZACIÓN', 19, y + 5.5);
    
    pdf.setTextColor(90, 90, 90);
    pdf.setFont('helvetica', 'normal');
    pdf.setFontSize(8);
    let lineY = y + 10;
    descLines.forEach((line: string) => {
      pdf.text(line, 19, lineY);
      lineY += 4.8;
    });
    
    y += cardHeight + 6;
  });
  
  // Call to Action Box
  const ctaHeight = 20;
  if (y + ctaHeight > 260) {
    pdf.addPage();
    drawPageDecorations(2);
    y = 28;
  }
  
  pdf.setFillColor(254, 251, 249);
  pdf.rect(15, y, 180, ctaHeight, 'F');
  
  pdf.setDrawColor(251, 218, 204);
  pdf.setLineWidth(0.2);
  pdf.rect(15, y, 180, ctaHeight, 'D');
  
  pdf.setTextColor(slate[0], slate[1], slate[2]);
  pdf.setFont('helvetica', 'bold');
  pdf.setFontSize(8.5);
  pdf.text('¿CÓMO SOLICITAR UNA COTIZACIÓN?', 105, y + 5.5, { align: 'center' });
  
  pdf.setTextColor(70, 70, 70);
  pdf.setFont('helvetica', 'normal');
  pdf.setFontSize(8);
  pdf.text('Envíe el código de este producto por correo electrónico o escríbanos directamente a nuestro WhatsApp', 105, y + 10.5, { align: 'center' });
  pdf.setTextColor(orange[0], orange[1], orange[2]);
  pdf.setFont('helvetica', 'bold');
  pdf.text('info@todohuincha.com   ·   WhatsApp/Fono: (45) 240 0000', 105, y + 15, { align: 'center' });
  
  pdf.save(`${title.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/[^a-z0-9]+/g,'-')}.pdf`);
}));
</script>

