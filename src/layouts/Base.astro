---
import {
  loadBranchesJson,
  loadCompanyJson,
  loadServicesJson,
  loadTeamJson,
} from '../lib/seo/loadCompanyJson.ts';
import { buildOrganizationGraph } from '../lib/seo/organization-graph.ts';

const {
  title = 'Todo Huincha',
  description = 'Soluciones de corte, maquinaria y servicio técnico especializado.',
  pageLevelJsonLd = [],
  canonical,
  noIndex = false,
} = Astro.props;
const pathname = Astro.url.pathname;
const extraNodes: Array<Record<string, unknown>> = Array.isArray(pageLevelJsonLd) ? pageLevelJsonLd : [];

const company = loadCompanyJson();
const branches = loadBranchesJson();
const services = loadServicesJson();
const team = loadTeamJson();
const graph = buildOrganizationGraph({
  company,
  branches,
  services,
  team,
  siteUrl: company.url,
});
const canonicalHref = canonical ?? new URL(pathname, company.url).toString();
---
<!doctype html>
<html lang="es-CL">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalHref} />
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex,nofollow" />}
    <title>{title}</title>
    <slot name="head" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(graph)} />
    {extraNodes.map((node) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(node)} />
    ))}
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">
        <img src="/logo-todohuincha.svg" alt="Todo Huincha" />
      </a>
      
      <button class="menu-toggle" id="menu-toggle-btn" aria-label="Abrir menú" aria-expanded="false">
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </button>

      <nav aria-label="Principal" id="site-nav">
        <a href="/" class={pathname === '/' ? 'active' : ''}>Inicio</a>
        <a href="/catalogo" class={pathname.startsWith('/catalogo') ? 'active' : ''}>Productos</a>
        <a href="/maquinaria" class={pathname.startsWith('/maquinaria') ? 'active' : ''}>Maquinaria</a>
        <a href="/empresa/" class={pathname.startsWith('/empresa') ? 'active' : ''}>Empresa</a>
        <a href="/sucursales/" class={pathname.startsWith('/sucursales') ? 'active' : ''}>Sucursales</a>
        <a href="/contacto" class={pathname.startsWith('/contacto') ? 'active' : ''}>Contacto</a>
      </nav>
    </header>
    <main><slot /></main>
    <footer>
      <strong>Comercializadora Todo Huincha Ltda.</strong>
      <span>{company.address.street}, {company.address.locality} · {company.phones[0]} · {company.emails[0]}</span>
    </footer>
    
    <script>
      const menuToggle = document.getElementById('menu-toggle-btn');
      const siteNav = document.getElementById('site-nav');
      
      if (menuToggle && siteNav) {
        menuToggle.addEventListener('click', () => {
          const isOpen = siteNav.classList.toggle('is-open');
          menuToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
          menuToggle.classList.toggle('is-active', isOpen);
        });
      }
    </script>
  </body>
</html>
<style is:global>
