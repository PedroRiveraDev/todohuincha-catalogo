---
// src/pages/catalogo/index.astro
// Catalog landing page. Slice 2 of catalog-v2-ui-migration: consumes
// src/lib/catalog.ts directly (bypasses the legacy shim), renders the
// grouped 8-group sidebar, per-row ItemTypeChip, context-aware WhatsApp
// CTA, search filter, PDF button, and JSON-LD ItemList schema.
//
// Refs:
//   openspec/changes/catalog-v2-ui-migration-slice-2/proposal.md
//   openspec/changes/catalog-v2-ui-migration-slice-2/design.md (section 8)

import Base from '../../layouts/Base.astro';
import { adapter } from '../../lib/catalog.ts';
import {
  groupCategoriesByGroup,
  sortItemsByDisplayName,
} from '../../lib/categories.ts';
import CategorySidebar from '../../components/CategorySidebar.astro';
import WhatsAppCta from '../../components/WhatsAppCta.astro';
import PdfDownloadButton from '../../components/PdfDownloadButton.astro';

const totalProducts = adapter.items.length;
const totalCategories = adapter.categories.length;
const totalServices = adapter.serviceCategories.length;
const sortedItems = sortItemsByDisplayName(adapter.items);
const groups = groupCategoriesByGroup(adapter.categories);

const rowsForPdf = sortedItems.map((it) => {
  const cat = adapter.getCategory(it.category_code);
  return `${it.sku} | ${it.display_name} | ${cat?.label ?? ''}`;
});

const GROUP_LABELS: Record<string, string> = {
  sierras: 'Sierras',
  consumibles: 'Consumibles',
  cuchillos: 'Cuchillos',
  herramientas: 'Herramientas',
  materiales: 'Materiales',
  servicios: 'Servicios',
  maquinaria: 'Maquinaria',
  instrumentos: 'Instrumentos',
};

function formatPrice(p: {
  is_price_available: boolean;
  formatted: string | null;
}): string {
  if (!p.is_price_available) return 'A cotizar';
  return p.formatted ?? 'Consultar';
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Todos los productos',
  numberOfItems: sortedItems.length,
  itemListElement: sortedItems.map((item, idx) => {
    const cat = adapter.getCategory(item.category_code);
    return {
      '@type': 'ListItem',
      position: idx + 1,
      name: item.display_name,
      url: `https://todohuincha.cl/productos/${cat?.slug ?? ''}/${encodeURIComponent(item.sku)}`,
    };
  }),
};
---
<Base
  title="Catálogo | Todo Huincha"
  description="Catálogo completo de productos Todo Huincha, disponible por cotización."
>
  <div class="catalog-hero-dark">
    <div class="catalog-hero-inner wrap">
      <div class="hero-left">
        <span class="eyebrow">Catálogo</span>
        <h1 id="cat-label">Todos los productos</h1>
        <p class="hero-subtitle">
          <span id="cat-count">{totalProducts}</span> productos · {totalCategories} categorías · {totalServices} servicios técnicos
        </p>
      </div>
      <div class="hero-right">
        <div id="hero-actions-bar" class="hero-actions-bar">
          <div class="search-wrapper">
            <input
              id="cat-search"
              class="catalog-search-dark"
              type="search"
              placeholder="Buscar por producto o código…"
              aria-label="Buscar productos"
              autocomplete="off"
            />
            <svg class="search-icon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          </div>
          <PdfDownloadButton
            title="Catálogo Todo Huincha"
            subtitle={`${totalProducts} productos en ${totalCategories} categorías`}
            rows={rowsForPdf}
          />
        </div>
      </div>
    </div>
  </div>

  <div class="catalog-layout wrap">
    <CategorySidebar
      categories={adapter.categories}
      activeSlug={null}
      totalProducts={totalProducts}
    />

    <div class="catalog-content">
      <div class="cat-table-header">
        <span>PRODUCTO</span>
        <span>CATEGORÍA</span>
        <span>CÓDIGO</span>
        <span>ACCIÓN</span>
      </div>

      <div class="catalog-list" id="cat-list">
        {sortedItems.map((item) => {
          const cat = adapter.getCategory(item.category_code);
          const catSlug = cat?.slug ?? '';
          const searchKey = [
            item.display_name,
            item.sku,
            cat?.label ?? '',
            item.search?.tokens?.join(' ') ?? '',
          ]
            .join(' ')
            .toLowerCase();
          const groupKey = cat?.group ?? '';
          return (
            <div
              class={`cat-row cat-row--${item.item_type}`}
              data-slug={catSlug}
              data-group={groupKey}
              data-search={searchKey}
              data-type={item.item_type}
            >
              <div class="cat-row-name">
                <div class="cat-row-name-text" title={item.display_name}>
                  {item.display_name}
                </div>
                <div class="cat-row-price">{formatPrice(item.pricing)}</div>
              </div>
              <span class="cat-row-tag">{cat?.label ?? '—'}</span>
              <span class="cat-row-code">Cód. {item.sku}</span>
              <span class="cat-row-actions">
                <a class="button cat-row-btn" href={`/productos/${catSlug}/${encodeURIComponent(item.sku)}`}>
                  Ver
                </a>
                <WhatsAppCta
                  context="sales"
                  productName={item.display_name}
                  sku={item.sku}
                  compact
                />
              </span>
            </div>
          );
        })}
      </div>

      <p class="catalog-empty" id="cat-empty" style="display:none">
        No se encontraron productos para esta búsqueda.
      </p>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Per-group WhatsApp CTAs at the end of each section. Rendered as a
       plain section list so JS-side search/filter applies the same
       visibility rules as the items above. Kept outside .cat-list to
       avoid polluting item rows. -->
  <section class="catalog-group-ctas wrap" aria-label="Cotizar por sección">
    {[...groups.entries()].map(([groupKey]) => (
      <div class="catalog-group-cta" data-group={groupKey}>
        <h2>{GROUP_LABELS[groupKey] ?? groupKey}</h2>
        <WhatsAppCta
          context={groupKey as 'sales' | 'repuestos' | 'machinery' | 'general'}
        />
      </div>
    ))}
    <div class="catalog-group-cta">
      <h2>Cotización general</h2>
      <WhatsAppCta context="general" />
    </div>
  </section>
</Base>

<style is:global>
  /* Inner column inside .cat-row: name on top, price below. */
  .cat-row-name {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
    padding: 2px 0;
  }
  .cat-row-name-text {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--ink, #292925);
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    word-break: break-word;
  }
  .cat-row-price {
    font-size: 0.78rem;
    color: var(--orange, #FB4D08);
    font-weight: 700;
    white-space: nowrap;
    letter-spacing: 0.01em;
  }
  .cat-row-actions {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  /* Per-section CTA strip at end of catalog */
  .catalog-group-ctas {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
    margin-top: 16px;
  }
  .catalog-group-cta {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 18px;
    border: 1px solid var(--line, #eadfd8);
    border-radius: var(--radius, 14px);
    background: var(--surface, #fff);
  }
  .catalog-group-cta h2 {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    color: var(--charcoal, #313E48);
  }
</style>

<script>
  // Vanilla JS filter: sidebar (by category) + search (debounced 100ms).
  // PDF data attrs are updated to match the visible rows, so the
  // PdfDownloadButton component always exports the current filtered set.
  let activeSlug = '__all__';
  let activeGroup: string | null = null;
  let searchTerm = '';
  let debounceTimer: number | undefined;

  function getVisibleRows(): HTMLElement[] {
    return [
      ...document.querySelectorAll<HTMLElement>('.cat-row:not(.is-hidden)'),
    ];
  }

  function render() {
    const rows = document.querySelectorAll<HTMLElement>('.cat-row');
    let visible = 0;
    rows.forEach((row) => {
      const slugMatch =
        activeSlug === '__all__' || row.dataset.slug === activeSlug;
      const groupMatch =
        activeGroup === null || row.dataset.group === activeGroup;
      const searchMatch =
        !searchTerm || (row.dataset.search ?? '').includes(searchTerm);
      const show = slugMatch && groupMatch && searchMatch;
      row.classList.toggle('is-hidden', !show);
      if (show) visible++;
    });
    const countEl = document.querySelector<HTMLElement>('#cat-count');
    const emptyEl = document.querySelector<HTMLElement>('#cat-empty');
    if (countEl) countEl.textContent = String(visible);
    if (emptyEl) emptyEl.style.display = visible > 0 ? 'none' : 'block';
    updatePdfData();
  }

  function activateCategory(slug: string) {
    activeSlug = slug;
    activeGroup = null;
    syncButtonStates();
    const labelEl = document.querySelector<HTMLElement>('#cat-label');
    const activeBtn = document.querySelector<HTMLButtonElement>(
      `.cat-sidebar-item[data-slug="${slug}"]`
    );
    if (labelEl && activeBtn) {
      const name =
        activeBtn.querySelector('.cat-sidebar-name')?.textContent ?? '';
      labelEl.textContent = slug === '__all__' ? 'Todos los productos' : name;
    }
    const searchInput = document.querySelector<HTMLInputElement>('#cat-search');
    if (searchInput) {
      searchInput.value = '';
      searchTerm = '';
    }
    render();
  }

  function activateGroup(groupKey: string) {
    activeGroup = groupKey;
    activeSlug = '__all__';
    syncButtonStates();
    const labelEl = document.querySelector<HTMLElement>('#cat-label');
    const groupBtn = document.querySelector<HTMLButtonElement>(
      `.cat-sidebar-group-header[data-group="${groupKey}"]`
    );
    if (labelEl && groupBtn) {
      const name =
        groupBtn.querySelector('.cat-sidebar-group-title')?.textContent ?? '';
      labelEl.textContent = name;
    }
    const searchInput = document.querySelector<HTMLInputElement>('#cat-search');
    if (searchInput) {
      searchInput.value = '';
      searchTerm = '';
    }
    render();
  }

  function syncButtonStates() {
    const items = document.querySelectorAll<HTMLButtonElement>('.cat-sidebar-item');
    items.forEach((btn) =>
      btn.classList.toggle('is-active', btn.dataset.slug === activeSlug)
    );
    const groups = document.querySelectorAll<HTMLButtonElement>('.cat-sidebar-group-header');
    groups.forEach((btn) =>
      btn.classList.toggle('is-active', btn.dataset.group === activeGroup)
    );
  }

  function updatePdfData() {
    const pdfBtn = document.querySelector<HTMLButtonElement>('#cat-pdf-btn');
    if (!pdfBtn) return;
    const visibleRows = getVisibleRows();
    const pdfRows = visibleRows.map((r) => {
      const code = r.querySelector('.cat-row-code')?.textContent ?? '';
      const name =
        r.querySelector('.cat-row-name-text')?.textContent ?? '';
      const category = r.querySelector('.cat-row-tag')?.textContent ?? '';
      return `${code} | ${name} | ${category}`;
    });
    const searchInput = document.querySelector<HTMLInputElement>('#cat-search');
    const searchActive = !!(
      searchInput && searchInput.value.trim().length > 0
    );
    if (activeSlug === '__all__') {
      pdfBtn.dataset.title = 'Catálogo Todo Huincha';
      if (searchActive) {
        pdfBtn.dataset.subtitle = `${visibleRows.length} productos encontrados para la búsqueda`;
      } else {
        const catCount =
          document.querySelectorAll('.cat-sidebar-item').length - 1;
        pdfBtn.dataset.subtitle = `${visibleRows.length} productos en ${catCount} categorías`;
      }
    } else {
      const activeBtn = document.querySelector<HTMLButtonElement>(
        `[data-slug="${activeSlug}"]`
      );
      const catName =
        activeBtn?.querySelector('.cat-sidebar-name')?.textContent ??
        activeSlug;
      pdfBtn.dataset.title = `Todo Huincha — ${catName}`;
      if (searchActive) {
        pdfBtn.dataset.subtitle = `${visibleRows.length} productos filtrados en esta categoría`;
      } else {
        pdfBtn.dataset.subtitle = `${visibleRows.length} productos en esta categoría`;
      }
    }
    pdfBtn.dataset.rows = JSON.stringify(pdfRows);
  }

  document
    .querySelectorAll<HTMLButtonElement>('.cat-sidebar-item')
    .forEach((btn) => {
      btn.addEventListener('click', () =>
        activateCategory(btn.dataset.slug ?? '__all__')
      );
    });

  document
    .querySelectorAll<HTMLButtonElement>('.cat-sidebar-group-header')
    .forEach((btn) => {
      btn.addEventListener('click', () => {
        const groupLi = btn.closest<HTMLElement>('.cat-sidebar-group');
        if (!groupLi) return;
        const isCollapsed = groupLi.classList.toggle('is-collapsed');
        btn.setAttribute('aria-expanded', String(!isCollapsed));
        try {
          const stored = JSON.parse(
            localStorage.getItem('cat:sidebar:collapsed') ?? '{}'
          ) as Record<string, boolean>;
          stored[groupLi.dataset.group ?? ''] = isCollapsed;
          localStorage.setItem('cat:sidebar:collapsed', JSON.stringify(stored));
        } catch {}
      });
    });

  // Restore collapsed state from localStorage on load.
  try {
    const stored = JSON.parse(
      localStorage.getItem('cat:sidebar:collapsed') ?? '{}'
    ) as Record<string, boolean>;
    for (const [groupKey, collapsed] of Object.entries(stored)) {
      if (!collapsed) continue;
      const groupLi = document.querySelector<HTMLElement>(
        `.cat-sidebar-group[data-group="${groupKey}"]`
      );
      if (groupLi) {
        groupLi.classList.add('is-collapsed');
        const btn = groupLi.querySelector<HTMLButtonElement>('.cat-sidebar-group-header');
        btn?.setAttribute('aria-expanded', 'false');
      }
    }
  } catch {}

  const searchInput = document.querySelector<HTMLInputElement>('#cat-search');
  if (searchInput) {
    searchInput.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = window.setTimeout(() => {
        searchTerm = searchInput.value.toLowerCase().trim();
        render();
      }, 100);
    });
  }

  render();

  // -------------------------------------------------------------------
  // Magic-bar: the #hero-actions-bar (search input + PDF button) starts
  // inside the catalog hero. On scroll past the hero, the SAME element
  // moves into the sticky header slot (#header-actions-slot) via FLIP
  // animation. On scroll back, it returns to the hero. Always one DOM
  // node, never duplicated.
  // -------------------------------------------------------------------
  const heroActions = document.getElementById('hero-actions-bar');
  const heroActionsHost = heroActions?.parentElement as HTMLElement | null;
  const headerActionsSlot = document.getElementById(
    'header-actions-slot'
  ) as HTMLElement | null;

  if (heroActions && heroActionsHost && headerActionsSlot) {
    let isFloating = false;
    let isAnimating = false;
    const HEADER_HEIGHT = 80;
    const ANIM_MS = 380;
    const TRIGGER_OFFSET = 24; // start moving slightly before the hero exits

    function flipMove(targetParent: HTMLElement): void {
      const startRect = heroActions!.getBoundingClientRect();
      targetParent.appendChild(heroActions!);
      // Mark the parent so the slot CSS scopes apply.
      heroActions!.classList.add('hero-actions-floating');
      const endRect = heroActions!.getBoundingClientRect();
      const dx = startRect.left - endRect.left;
      const dy = startRect.top - endRect.top;

      heroActions!.style.transition = 'none';
      heroActions!.style.transform = `translate(${dx}px, ${dy}px)`;

      // Force reflow so the browser registers the pre-transform state.
      void heroActions!.getBoundingClientRect();

      heroActions!.style.transition = `transform ${ANIM_MS}ms cubic-bezier(0.16, 1, 0.3, 1)`;
      heroActions!.style.transform = '';

      const onEnd = () => {
        heroActions!.removeEventListener('transitionend', onEnd);
        heroActions!.style.transition = '';
        isAnimating = false;
      };
      heroActions!.addEventListener('transitionend', onEnd);
    }

    function maybeFloat(): void {
      if (isAnimating) return;
      // CRITICAL: measure the HERO element, not the actions bar.
      // Once the bar is floating in the header slot, its own rect sits
      // inside the sticky header (always at y ~25-80) so checking the
      // bar's rect would always report "shouldFloat = true" and the
      // bar would never return to the hero on scroll-up.
      const heroEl = document.querySelector<HTMLElement>('.catalog-hero-dark');
      if (!heroEl) return;
      const heroRect = heroEl.getBoundingClientRect();
      const shouldFloat = heroRect.bottom < HEADER_HEIGHT + TRIGGER_OFFSET;

      if (shouldFloat && !isFloating) {
        isFloating = true;
        isAnimating = true;
        flipMove(headerActionsSlot!);
      } else if (!shouldFloat && isFloating) {
        isFloating = false;
        isAnimating = true;
        flipMove(heroActionsHost!);
      }
    }

    let scrollRaf: number | undefined;
    function onScroll(): void {
      if (scrollRaf !== undefined) return;
      scrollRaf = window.requestAnimationFrame(() => {
        scrollRaf = undefined;
        maybeFloat();
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    maybeFloat();
  }
</script>