---
// src/pages/catalogo/index.astro
// Catalog landing page. Slice 2 of catalog-v2-ui-migration: consumes
// src/lib/catalog.ts directly (bypasses the legacy shim), renders the
// grouped 8-group sidebar, per-row ItemTypeChip, context-aware WhatsApp
// CTA, search filter, PDF button, and JSON-LD ItemList schema.
//
// Refs:
//   openspec/changes/catalog-v2-ui-migration-slice-2/proposal.md
//   openspec/changes/catalog-v2-ui-migration-slice-2/design.md (section 8)

import Base from '../../layouts/Base.astro';
import { adapter } from '../../lib/catalog.ts';
import {
  groupCategoriesByGroup,
  sortItemsByDisplayName,
} from '../../lib/categories.ts';
import CategorySidebar from '../../components/CategorySidebar.astro';
import WhatsAppCta from '../../components/WhatsAppCta.astro';
import PdfDownloadButton from '../../components/PdfDownloadButton.astro';
import PdfOptionsDialog from '../../components/PdfOptionsDialog.astro';

const totalProducts = adapter.items.length;
const totalCategories = adapter.categories.length;
const totalServices = adapter.serviceCategories.length;
const sortedItems = sortItemsByDisplayName(adapter.items);
const groups = groupCategoriesByGroup(adapter.categories);

const rowsForPdf = sortedItems.map((it) => {
  const cat = adapter.getCategory(it.category_code);
  return `${it.sku} | ${it.display_name} | ${cat?.label ?? ''}`;
});

const GROUP_LABELS: Record<string, string> = {
  sierras: 'Sierras',
  consumibles: 'Consumibles',
  cuchillos: 'Cuchillos',
  herramientas: 'Herramientas',
  materiales: 'Materiales',
  servicios: 'Servicios',
  maquinaria: 'Maquinaria',
  instrumentos: 'Instrumentos',
};

function formatPrice(p: {
  is_price_available: boolean;
  formatted: string | null;
}): string {
  if (!p.is_price_available) return 'A cotizar';
  return p.formatted ?? 'Consultar';
}

/**
 * Build the minimal catalog payload exposed to the client-side PDF
 * generator. Only fields the per-type dispatcher reads are included so
 * the inline JSON stays small (~30 KB for 681 items).
 */
function buildPdfPayload(adapter: typeof import('../../lib/catalog.ts').adapter) {
  return {
    catalog_assets: (adapter as unknown as { catalog_assets?: unknown }).catalog_assets ?? null,
    families: adapter.families.map((f) => {
      const fam = f as { family_key?: string; assets?: unknown };
      return { sku: fam.family_key ?? null, assets: fam.assets ?? null };
    }),
    categories: adapter.categories.map((c) => ({
      label: c.label,
      assets: (c as unknown as { assets?: unknown }).assets ?? null,
    })),
    items: adapter.items.map((it) => ({
      sku: it.sku,
      item_type: it.item_type,
      category_label: it.category_label,
      assets: it.assets ?? null,
      machinery_profile: it.machinery_profile ?? null,
      service_profile: it.service_profile ?? null,
      specifications: it.specifications ?? {},
      pricing: it.pricing,
    })),
  };
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Todos los productos',
  numberOfItems: sortedItems.length,
  itemListElement: sortedItems.map((item, idx) => {
    const cat = adapter.getCategory(item.category_code);
    return {
      '@type': 'ListItem',
      position: idx + 1,
      name: item.display_name,
      url: `https://todohuincha.cl/productos/${cat?.slug ?? ''}/${encodeURIComponent(item.sku)}`,
    };
  }),
};
---
<Base
  title="Catálogo | Todo Huincha"
  description="Catálogo completo de productos Todo Huincha, disponible por cotización."
>
  <div class="catalog-hero-dark">
    <div class="catalog-hero-inner wrap">
      <div class="hero-left">
        <span class="eyebrow">Catálogo</span>
        <h1 id="cat-label">Todos los productos</h1>
        <p class="hero-subtitle">
          <span id="cat-count">{totalProducts}</span> productos · {totalCategories} categorías · {totalServices} servicios técnicos
        </p>
      </div>
      <div class="hero-right">
        <div id="hero-actions-bar" class="hero-actions-bar">
          <div class="search-wrapper">
            <input
              id="cat-search"
              class="catalog-search-dark"
              type="search"
              placeholder="Buscar por producto o código…"
              aria-label="Buscar productos"
              autocomplete="off"
            />
            <svg class="search-icon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          </div>
          <PdfDownloadButton
            title="Catálogo Todo Huincha"
            subtitle={`${totalProducts} productos en ${totalCategories} categorías`}
            rows={rowsForPdf}
          />
        </div>
      </div>
    </div>
  </div>

  <div class="catalog-layout wrap">
    <CategorySidebar
      categories={adapter.categories}
      activeSlug={null}
      totalProducts={totalProducts}
    />

    <div class="catalog-content">
      <div class="cat-table-header">
        <span>PRODUCTO</span>
        <span>CATEGORÍA</span>
        <span>CÓDIGO</span>
        <span>ACCIÓN</span>
      </div>

      <div class="catalog-list" id="cat-list">
        {sortedItems.map((item) => {
          const cat = adapter.getCategory(item.category_code);
          const catSlug = cat?.slug ?? '';
          const searchKey = [
            item.display_name,
            item.sku,
            cat?.label ?? '',
            item.search?.tokens?.join(' ') ?? '',
          ]
            .join(' ')
            .toLowerCase();
          const groupKey = cat?.group ?? '';
          return (
            <div
              class={`cat-row cat-row--${item.item_type}`}
              data-slug={catSlug}
              data-group={groupKey}
              data-search={searchKey}
              data-type={item.item_type}
            >
              <div class="cat-row-name">
                <div class="cat-row-name-text" title={item.display_name}>
                  {item.display_name}
                </div>
                <div class="cat-row-price">{formatPrice(item.pricing)}</div>
              </div>
              <span class="cat-row-tag">{cat?.label ?? '—'}</span>
              <span class="cat-row-code">Cód. {item.sku}</span>
              <span class="cat-row-actions">
                <a class="button cat-row-btn" href={`/productos/${catSlug}/${encodeURIComponent(item.sku)}`}>
                  Ver
                </a>
                <WhatsAppCta
                  context="sales"
                  productName={item.display_name}
                  sku={item.sku}
                  compact
                />
              </span>
            </div>
          );
        })}
      </div>

      <p class="catalog-empty" id="cat-empty" style="display:none">
        No se encontraron productos para esta búsqueda.
      </p>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Catalog payload exposed to the PDF generator so the per-type
       dispatcher can render machinery sheets / service cards. Only the
       fields the dispatcher reads are exposed; everything else stays
       server-rendered. -->
  <script is:inline define:vars={{ catalogPayload: buildPdfPayload(adapter) }}>
    window.__CATALOG_PAYLOAD__ = catalogPayload;
  </script>

  <!-- Catalog PDF options popup (native <dialog>, hidden by default). -->
  <PdfOptionsDialog />

  <!-- Per-group WhatsApp CTAs at the end of each section. Rendered as a
       plain section list so JS-side search/filter applies the same
       visibility rules as the items above. Kept outside .cat-list to
       avoid polluting item rows. -->
  <section class="catalog-group-ctas wrap" aria-label="Cotizar por sección">
    {[...groups.entries()].map(([groupKey]) => (
      <div class="catalog-group-cta" data-group={groupKey}>
        <h2>{GROUP_LABELS[groupKey] ?? groupKey}</h2>
        <WhatsAppCta
          context={groupKey as 'sales' | 'repuestos' | 'machinery' | 'general'}
        />
      </div>
    ))}
    <div class="catalog-group-cta">
      <h2>Cotización general</h2>
      <WhatsAppCta context="general" />
    </div>
  </section>
</Base>

<style is:global>
  /* Inner column inside .cat-row: name on top, price below. */
  .cat-row-name {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
    padding: 2px 0;
  }
  .cat-row-name-text {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--ink, #292925);
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    word-break: break-word;
  }
  .cat-row-price {
    font-size: 0.78rem;
    color: var(--orange, #FB4D08);
    font-weight: 700;
    white-space: nowrap;
    letter-spacing: 0.01em;
  }
  .cat-row-actions {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  /* Per-section CTA strip at end of catalog */
  .catalog-group-ctas {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
    margin-top: 16px;
  }
  .catalog-group-cta {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 18px;
    border: 1px solid var(--line, #eadfd8);
    border-radius: var(--radius, 14px);
    background: var(--surface, #fff);
  }
  .catalog-group-cta h2 {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    color: var(--charcoal, #313E48);
  }
</style>

<script>
  // Unified selection state for the catalog sidebar.
  //
  // The sidebar exposes a checkbox on every row (master + 8 groups + 21
  // subcategories). The selection is a single Set<string> of subcategory
  // slugs that drives BOTH the center table filter AND the PDF data-rows
  // attribute (rebuilt from currently visible rows on every change).
  //
  // Click contract (matches src/components/CategorySidebar.astro):
  //   - clicking the checkbox toggles that slug in the set (additive)
  //   - clicking the label text performs a unitary filter (replaces)
  //   - the master checkbox is a convenience for "all/none"
  //   - group checkboxes cascade to their subcategories
  //   - the chevron is a sibling button, so it never toggles a checkbox
  //
  // Persistence: localStorage[cat:sidebar:selection] is a JSON array of
  // slugs. Empty / missing storage -> default = all 21 subcategories
  // selected (equivalent to "Todos los productos" checked).
  const SELECTION_KEY = 'cat:sidebar:selection';
  const COLLAPSE_KEY = 'cat:sidebar:collapsed';

  const slugToName = new Map<string, string>();
  const allSubcategorySlugs: string[] = [];
  const groupSlugs = new Map<string, string[]>();
  let selectedSlugs: Set<string> = new Set();
  let searchTerm = '';
  let debounceTimer: number | undefined;

  function loadSelection(): Set<string> {
    try {
      const raw = localStorage.getItem(SELECTION_KEY);
      if (!raw) return new Set();
      const arr = JSON.parse(raw);
      if (!Array.isArray(arr)) return new Set();
      return new Set(arr.filter((s): s is string => typeof s === 'string'));
    } catch {
      return new Set();
    }
  }

  function saveSelection() {
    try {
      localStorage.setItem(
        SELECTION_KEY,
        JSON.stringify([...selectedSlugs].sort())
      );
    } catch {}
  }

  function isAllSelected(): boolean {
    return (
      allSubcategorySlugs.length > 0 &&
      selectedSlugs.size === allSubcategorySlugs.length
    );
  }

  function syncCheckboxes() {
    const masterChk = document.querySelector<HTMLInputElement>('#cat-chk-all');
    if (masterChk) {
      const all = isAllSelected();
      const none = selectedSlugs.size === 0;
      masterChk.checked = all;
      masterChk.indeterminate = !all && !none;
    }

    document
      .querySelectorAll<HTMLInputElement>('.cat-sidebar-group-checkbox')
      .forEach((chk) => {
        const groupKey = chk.dataset.group ?? '';
        const slugs = groupSlugs.get(groupKey) ?? [];
        if (slugs.length === 0) {
          chk.checked = false;
          chk.indeterminate = false;
          return;
        }
        const hit = slugs.filter((s) => selectedSlugs.has(s)).length;
        chk.checked = hit === slugs.length;
        chk.indeterminate = hit > 0 && hit < slugs.length;
      });

    document
      .querySelectorAll<HTMLInputElement>('.cat-sidebar-checkbox[data-slug]')
      .forEach((chk) => {
        const slug = chk.dataset.slug ?? '';
        if (slug === '__all__') return;
        chk.checked = selectedSlugs.has(slug);
      });
  }

  function applyFilter() {
    const rows = document.querySelectorAll<HTMLElement>('.cat-row');
    let visible = 0;
    const showAll = isAllSelected() || selectedSlugs.size === 0;
    rows.forEach((row) => {
      const slugMatch =
        showAll || selectedSlugs.has(row.dataset.slug ?? '');
      const searchMatch =
        !searchTerm || (row.dataset.search ?? '').includes(searchTerm);
      const show = slugMatch && searchMatch;
      row.classList.toggle('is-hidden', !show);
      if (show) visible++;
    });
    const countEl = document.querySelector<HTMLElement>('#cat-count');
    const emptyEl = document.querySelector<HTMLElement>('#cat-empty');
    if (countEl) countEl.textContent = String(visible);
    if (emptyEl) emptyEl.style.display = visible > 0 ? 'none' : 'block';
    updateLabel();
    updatePdfData(visible);
  }

  function updateLabel() {
    const labelEl = document.querySelector<HTMLElement>('#cat-label');
    if (!labelEl) return;
    const showAll = isAllSelected() || selectedSlugs.size === 0;
    if (showAll) {
      labelEl.textContent = 'Todos los productos';
      return;
    }
    if (selectedSlugs.size === 1) {
      const slug = [...selectedSlugs][0];
      labelEl.textContent = slugToName.get(slug) ?? slug;
      return;
    }
    labelEl.textContent = `Selección personalizada (${selectedSlugs.size} categorías)`;
  }

  function updatePdfData(visibleCount: number) {
    const pdfBtn = document.querySelector<HTMLButtonElement>('#cat-pdf-btn');
    if (!pdfBtn) return;
    const visibleRows = [
      ...document.querySelectorAll<HTMLElement>('.cat-row:not(.is-hidden)'),
    ];
    const pdfRows = visibleRows.map((r) => {
      const code = r.querySelector('.cat-row-code')?.textContent ?? '';
      const name = r.querySelector('.cat-row-name-text')?.textContent ?? '';
      const category = r.querySelector('.cat-row-tag')?.textContent ?? '';
      return `${code} | ${name} | ${category}`;
    });
    const searchInput = document.querySelector<HTMLInputElement>('#cat-search');
    const searchActive = !!(
      searchInput && searchInput.value.trim().length > 0
    );
    const showAll = isAllSelected() || selectedSlugs.size === 0;
    if (showAll) {
      pdfBtn.dataset.title = 'Catálogo Todo Huincha';
      pdfBtn.dataset.subtitle = searchActive
        ? `${visibleCount} productos encontrados para la búsqueda`
        : `${visibleCount} productos en ${allSubcategorySlugs.length} categorías`;
    } else {
      const firstSlug = [...selectedSlugs][0];
      const catName =
        (firstSlug && slugToName.get(firstSlug)) || 'Selección';
      const titleSuffix =
        selectedSlugs.size === 1
          ? catName
          : `Selección (${selectedSlugs.size} categorías)`;
      pdfBtn.dataset.title = `Todo Huincha — ${titleSuffix}`;
      pdfBtn.dataset.subtitle = searchActive
        ? `${visibleCount} productos filtrados en esta selección`
        : `${visibleCount} productos en esta selección`;
    }
    pdfBtn.dataset.rows = JSON.stringify(pdfRows);
  }

  function onMasterChange(checked: boolean) {
    if (checked) {
      allSubcategorySlugs.forEach((s) => selectedSlugs.add(s));
    } else {
      selectedSlugs.clear();
    }
    afterSelectionChange();
  }

  function onGroupChange(groupKey: string, checked: boolean) {
    const slugs = groupSlugs.get(groupKey) ?? [];
    if (checked) {
      slugs.forEach((s) => selectedSlugs.add(s));
    } else {
      slugs.forEach((s) => selectedSlugs.delete(s));
    }
    afterSelectionChange();
  }

  function onSubcategoryChange(slug: string, checked: boolean) {
    if (checked) selectedSlugs.add(slug);
    else selectedSlugs.delete(slug);
    afterSelectionChange();
  }

  function onLabelClick(slug: string) {
    if (slug === '__all__') {
      selectedSlugs.clear();
      allSubcategorySlugs.forEach((s) => selectedSlugs.add(s));
    } else {
      selectedSlugs = new Set([slug]);
    }
    afterSelectionChange();
  }

  function onGroupLabelClick(groupKey: string) {
    const slugs = groupSlugs.get(groupKey) ?? [];
    selectedSlugs = new Set(slugs);
    afterSelectionChange();
  }

  function afterSelectionChange() {
    syncCheckboxes();
    saveSelection();
    applyFilter();
  }

  // Build slug/name/group maps from the sidebar DOM so the script
  // doesn't need a JSON data bridge from Astro's frontmatter.
  document
    .querySelectorAll<HTMLInputElement>('.cat-sidebar-checkbox[data-slug]')
    .forEach((input) => {
      const slug = input.dataset.slug ?? '';
      if (slug === '__all__' || slug === '') return;
      allSubcategorySlugs.push(slug);
      const name =
        input
          .closest('label')
          ?.querySelector('.cat-sidebar-name')
          ?.textContent?.trim() ?? slug;
      slugToName.set(slug, name);
      const groupKey = input.dataset.group ?? '';
      if (groupKey) {
        const list = groupSlugs.get(groupKey) ?? [];
        list.push(slug);
        groupSlugs.set(groupKey, list);
      }
    });

  // Restore selection from localStorage; empty/missing -> all selected.
  selectedSlugs = loadSelection();
  if (selectedSlugs.size === 0) {
    allSubcategorySlugs.forEach((s) => selectedSlugs.add(s));
  }

  // Master checkbox: change handler.
  const masterChk = document.querySelector<HTMLInputElement>('#cat-chk-all');
  if (masterChk) {
    masterChk.addEventListener('change', (e) => {
      onMasterChange((e.target as HTMLInputElement).checked);
    });
  }

  // Master label: clicking the label text (not the checkbox) is a
  // unitary filter -> select all. Distinguish via event.target.
  const masterLabel = document.querySelector<HTMLLabelElement>(
    'label[for="cat-chk-all"]'
  );
  if (masterLabel) {
    masterLabel.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).tagName === 'INPUT') return;
      e.preventDefault();
      onLabelClick('__all__');
    });
  }

  // Group checkboxes: change handler cascades to all sub-slugs.
  document
    .querySelectorAll<HTMLInputElement>('.cat-sidebar-group-checkbox')
    .forEach((chk) => {
      chk.addEventListener('change', (e) => {
        const input = e.target as HTMLInputElement;
        onGroupChange(input.dataset.group ?? '', input.checked);
      });
    });

  // Group labels: label click -> unitary filter by group.
  document
    .querySelectorAll<HTMLLabelElement>('.cat-sidebar-group-label')
    .forEach((lbl) => {
      const forAttr = lbl.getAttribute('for') ?? '';
      const groupKey = forAttr.replace(/^cat-chk-group-/, '');
      if (!groupKey) return;
      lbl.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).tagName === 'INPUT') return;
        e.preventDefault();
        onGroupLabelClick(groupKey);
      });
    });

  // Subcategory checkboxes + their wrapping labels.
  document
    .querySelectorAll<HTMLInputElement>('.cat-sidebar-checkbox[data-slug]')
    .forEach((chk) => {
      const slug = chk.dataset.slug ?? '';
      if (slug === '__all__' || slug === '') return;
      chk.addEventListener('change', (e) => {
        const input = e.target as HTMLInputElement;
        onSubcategoryChange(slug, input.checked);
      });
      const label = chk.closest('label');
      if (label) {
        label.addEventListener('click', (e) => {
          if ((e.target as HTMLElement).tagName === 'INPUT') return;
          e.preventDefault();
          onLabelClick(slug);
        });
      }
    });

  // Group collapse: chevron button toggles the .is-collapsed class on
  // the parent <li> and persists the boolean map to localStorage.
  document
    .querySelectorAll<HTMLButtonElement>('.cat-sidebar-group-chevron-btn')
    .forEach((btn) => {
      btn.addEventListener('click', () => {
        const groupLi = btn.closest<HTMLElement>('.cat-sidebar-group');
        if (!groupLi) return;
        const isCollapsed = groupLi.classList.toggle('is-collapsed');
        btn.setAttribute('aria-expanded', String(!isCollapsed));
        try {
          const stored = JSON.parse(
            localStorage.getItem(COLLAPSE_KEY) ?? '{}'
          ) as Record<string, boolean>;
          stored[groupLi.dataset.group ?? ''] = isCollapsed;
          localStorage.setItem(COLLAPSE_KEY, JSON.stringify(stored));
        } catch {}
      });
    });

  // Restore collapsed state from localStorage on load.
  try {
    const stored = JSON.parse(
      localStorage.getItem(COLLAPSE_KEY) ?? '{}'
    ) as Record<string, boolean>;
    for (const [groupKey, collapsed] of Object.entries(stored)) {
      if (!collapsed) continue;
      const groupLi = document.querySelector<HTMLElement>(
        `.cat-sidebar-group[data-group="${groupKey}"]`
      );
      if (groupLi) {
        groupLi.classList.add('is-collapsed');
        const btn = groupLi.querySelector<HTMLButtonElement>(
          '.cat-sidebar-group-chevron-btn'
        );
        btn?.setAttribute('aria-expanded', 'false');
      }
    }
  } catch {}

  // Search: 100ms debounce, AND on top of the current selection.
  const searchInput = document.querySelector<HTMLInputElement>('#cat-search');
  if (searchInput) {
    searchInput.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = window.setTimeout(() => {
        searchTerm = searchInput.value.toLowerCase().trim();
        applyFilter();
      }, 100);
    });
  }

  syncCheckboxes();
  applyFilter();

  // -------------------------------------------------------------------
  // Magic-bar: the #hero-actions-bar (search input + PDF button) starts
  // inside the catalog hero. On scroll past the hero, the SAME element
  // moves into the sticky header slot (#header-actions-slot) via FLIP
  // animation. On scroll back, it returns to the hero. Always one DOM
  // node, never duplicated.
  // -------------------------------------------------------------------
  const heroActions = document.getElementById('hero-actions-bar');
  const heroActionsHost = heroActions?.parentElement as HTMLElement | null;
  const headerActionsSlot = document.getElementById(
    'header-actions-slot'
  ) as HTMLElement | null;

  if (heroActions && heroActionsHost && headerActionsSlot) {
    let isFloating = false;
    let isAnimating = false;
    const HEADER_HEIGHT = 80;
    const ANIM_MS = 380;
    const TRIGGER_OFFSET = 24; // start moving slightly before the hero exits

    function flipMove(targetParent: HTMLElement): void {
      const startRect = heroActions!.getBoundingClientRect();
      targetParent.appendChild(heroActions!);
      // Mark the parent so the slot CSS scopes apply.
      heroActions!.classList.add('hero-actions-floating');
      const endRect = heroActions!.getBoundingClientRect();
      const dx = startRect.left - endRect.left;
      const dy = startRect.top - endRect.top;

      // Edge case: if the bar's old position is way above the viewport
      // (e.g. user scrolled fast past the hero), running the FLIP
      // animation would visually start from a negative-Y transform and
      // the bar would be invisible for the entire 380ms. In that case
      // we skip the animation and just snap to the new position.
      const START_OFFSCREEN_THRESHOLD = -120;
      if (startRect.top < START_OFFSCREEN_THRESHOLD) {
        heroActions!.style.transition = 'none';
        heroActions!.style.transform = '';
        setTimeout(() => {
          isAnimating = false;
        }, 0);
        return;
      }

      heroActions!.style.transition = 'none';
      heroActions!.style.transform = `translate(${dx}px, ${dy}px)`;

      // Force reflow so the browser registers the pre-transform state.
      void heroActions!.getBoundingClientRect();

      heroActions!.style.transition = `transform ${ANIM_MS}ms cubic-bezier(0.16, 1, 0.3, 1)`;
      heroActions!.style.transform = '';

      const onEnd = () => {
        heroActions!.removeEventListener('transitionend', onEnd);
        heroActions!.style.transition = '';
        isAnimating = false;
      };
      heroActions!.addEventListener('transitionend', onEnd);
    }

    function maybeFloat(): void {
      if (isAnimating) return;
      // CRITICAL: measure the HERO element, not the actions bar.
      // Once the bar is floating in the header slot, its own rect sits
      // inside the sticky header (always at y ~25-80) so checking the
      // bar's rect would always report "shouldFloat = true" and the
      // bar would never return to the hero on scroll-up.
      const heroEl = document.querySelector<HTMLElement>('.catalog-hero-dark');
      if (!heroEl) return;
      const heroRect = heroEl.getBoundingClientRect();
      // Hysteresis: different thresholds for going-floating vs
      // returning-to-hero. Without this, fast scrolls near the boundary
      // cause the bar to flap between hero and header in consecutive
      // animation frames.
      const UNFLOAT_THRESHOLD = HEADER_HEIGHT + TRIGGER_OFFSET + 48;
      const threshold = isFloating ? UNFLOAT_THRESHOLD : HEADER_HEIGHT + TRIGGER_OFFSET;
      const shouldFloat = heroRect.bottom < threshold;

      if (shouldFloat && !isFloating) {
        isFloating = true;
        isAnimating = true;
        flipMove(headerActionsSlot!);
      } else if (!shouldFloat && isFloating) {
        isFloating = false;
        isAnimating = true;
        flipMove(heroActionsHost!);
      }
    }

    let scrollRaf: number | undefined;
    function onScroll(): void {
      if (scrollRaf !== undefined) return;
      scrollRaf = window.requestAnimationFrame(() => {
        scrollRaf = undefined;
        maybeFloat();
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    maybeFloat();
  }
</script>