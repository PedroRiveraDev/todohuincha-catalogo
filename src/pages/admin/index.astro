---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getCategorySummaries, getOutputSummaries, getRawCatalogMetrics } from '../../lib/admin-ui-data';

const rawMetrics = getRawCatalogMetrics();
const outputs = getOutputSummaries();
const categories = getCategorySummaries();
const enabledOutputs = outputs.filter((output) => output.enabled).length;
---

<AdminLayout title="Admin Todo Huincha" section="dashboard">
  <span slot="title">Centro de control del catálogo</span>

  <section class="admin-page-grid" aria-labelledby="summary-title">
    <div class="metric-grid" aria-label="Resumen bruto del JSON fuente">
      <article class="metric-card">
        <span>Productos en JSON bruto</span>
        <strong>{rawMetrics.products}</strong>
      </article>
      <article class="metric-card">
        <span>Categorías en JSON bruto</span>
        <strong>{rawMetrics.categories}</strong>
      </article>
      <article class="metric-card">
        <span>Familias en JSON bruto</span>
        <strong>{rawMetrics.families}</strong>
      </article>
      <article class="metric-card">
        <span>Salidas activas</span>
        <strong>{enabledOutputs}</strong>
      </article>
    </div>

    <article class="admin-card intro-card">
      <div>
        <span class="admin-kicker">Primer slice visible</span>
        <h2 id="summary-title">Una interfaz clara para configurar el PDF sin tocar el JSON a mano.</h2>
        <p>Esta versión usa datos reales del catálogo y mantiene los cambios en modo visual. Las escrituras quedan bloqueadas hasta completar validación, diff y permisos.</p>
      </div>
      <a class="admin-button" href="/admin/outputs/full-catalog">Abrir editor</a>
    </article>

    <div class="dashboard-columns">
      <article class="admin-card">
        <h2>Salidas PDF</h2>
        <p>{outputs.length} configuraciones detectadas en <code>catalog_generation.output_types</code>.</p>
        <div class="mini-list">
          {outputs.map((output) => (
            output.key === 'full_catalog_pdf' ? (
              <a href="/admin/outputs/full-catalog">
                <span>{output.label}</span>
                <strong>Editable</strong>
              </a>
            ) : (
              <div class="mini-list__readonly" aria-disabled="true">
                <span>{output.label}</span>
                <strong>Solo lectura</strong>
              </div>
            )
          ))}
        </div>
      </article>

      <article class="admin-card">
        <h2>Categorías con contenido</h2>
        <p>Las descripciones y banners vienen del diccionario existente.</p>
        <div class="mini-list">
          {categories.slice(0, 5).map((category) => (
            <a href="/admin/categories">
              <span>{category.label}</span>
              <strong>{category.productsCount} items</strong>
            </a>
          ))}
        </div>
      </article>
    </div>
  </section>
</AdminLayout>

<style>
  .intro-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 18px;
    align-items: end;
  }
  .intro-card h2 { max-width: 820px; font-size: 1.55rem; }
  .intro-card p { max-width: 760px; }
  .dashboard-columns { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  .mini-list { display: grid; gap: 8px; margin-top: 16px; }
  .mini-list a, .mini-list__readonly {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    padding: 12px;
    border-radius: 12px;
    color: inherit;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.045);
    border: 1px solid var(--admin-line);
  }
  .mini-list__readonly { opacity: 0.68; cursor: not-allowed; }
  .mini-list span { color: var(--admin-muted); }
  .mini-list strong { color: var(--admin-accent); white-space: nowrap; }
  code { color: var(--admin-accent); }
  @media (max-width: 860px) {
    .intro-card, .dashboard-columns { grid-template-columns: 1fr; }
  }
</style>
