---
import InstitutionalLayout from '../../layouts/InstitutionalLayout.astro';
import {
  loadBranchesJson,
  loadCompanyJson,
} from '../../lib/seo/loadCompanyJson.ts';
import { buildBreadcrumbList, buildWebPage } from '../../lib/seo/jsonld.ts';

export async function getStaticPaths() {
  const branches = loadBranchesJson();
  return branches.map((branch) => ({
    params: { slug: branch.slug },
    props: { branch },
  }));
}

const { branch } = Astro.props;
const company = loadCompanyJson();
const pageUrl = new URL(`/sucursales/${branch.slug}/`, company.url).toString();

const crumb = buildBreadcrumbList({
  items: [
    { name: 'Inicio', item: company.url },
    { name: 'Sucursales', item: new URL('/sucursales/', company.url).toString() },
    { name: branch.name, item: pageUrl },
  ],
});

const pageNode = buildWebPage({
  url: pageUrl,
  name: `${branch.name} | Todo Huincha`,
  description: `Sucursal ${branch.name} en ${branch.city}. Dirección: ${branch.address.street}. Teléfono: ${branch.phone}. Horario: ${branch.hours}.`,
  inLanguage: 'es-CL',
  isPartOf: 'SITE',
  breadcrumb: crumb.itemListElement[crumb.itemListElement.length - 1].item,
});

// JSON-LD LocalBusiness para la sucursal
const localBusinessJsonLd = {
  '@context': 'https://schema.org',
  '@type': branch.isHeadquarters ? 'Headquarters' : 'LocalBusiness',
  '@id': `${pageUrl}#branch`,
  'name': branch.name,
  'image': new URL('/logo-todohuincha.svg', company.url).toString(),
  'telephone': branch.phone,
  'url': pageUrl,
  'address': {
    '@type': 'PostalAddress',
    'streetAddress': branch.address.street,
    'addressLocality': branch.address.locality,
    'addressRegion': branch.address.region,
    'addressCountry': 'CL',
  },
  'geo': {
    '@type': 'GeoCoordinates',
    'latitude': branch.address.geo.lat,
    'longitude': branch.address.geo.lng,
  },
  'openingHoursSpecification': [
    {
      '@type': 'OpeningHoursSpecification',
      'dayOfWeek': ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      'opens': '08:30',
      'closes': branch.hours.includes('18:30') ? '18:30' : '18:00',
    }
  ]
};

const breadcrumbs = [
  { name: 'Inicio', url: '/' },
  { name: 'Sucursales', url: '/sucursales/' },
  { name: branch.city, url: `/sucursales/${branch.slug}/` },
];
---
<InstitutionalLayout
  title={`${branch.name} | Comercializadora Todo Huincha`}
  description={`Dirección, teléfono, mapa de ubicación y horarios de atención de la sucursal de Todo Huincha en ${branch.city}.`}
  pageLevelJsonLd={[pageNode, crumb, localBusinessJsonLd]}
  breadcrumbs={breadcrumbs}
>
  <div class="inst-wrap">
    <span class="eyebrow">Detalles de sucursal</span>
    <h1>{branch.name}</h1>
    <p class="lede">Información de contacto, ubicación y horarios de atención para nuestra sucursal de {branch.city}.</p>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-top: 32px; align-items: start;">
      <div style="border: 1px solid var(--line); border-radius: var(--radius); padding: 24px; background: var(--surface); display: grid; gap: 16px; box-shadow: var(--shadow);">
        <h2 style="margin: 0 0 8px; font-size: 1.35rem; color: var(--charcoal);">Información General</h2>
        <p style="margin: 0; font-size: 1rem; color: var(--ink);"><strong>Dirección:</strong><br/>{branch.address.street}<br/>{branch.address.locality}, {branch.address.region}</p>
        <p style="margin: 0; font-size: 1rem; color: var(--ink);"><strong>Teléfono:</strong><br/>{branch.phone}</p>
        <p style="margin: 0; font-size: 1rem; color: var(--ink);"><strong>Horario de Atención:</strong><br/>{branch.hours}</p>
        <div style="margin-top: 12px;">
          <a href={branch.mapUrl} target="_blank" rel="noopener noreferrer" class="button" style="width: 100%; text-align: center;">¿Cómo llegar? (Google Maps)</a>
        </div>
      </div>

      <div style="border: 1px solid var(--line); border-radius: var(--radius); padding: 12px; background: var(--surface); box-shadow: var(--shadow); height: 100%; min-height: 320px; display: flex; align-items: center; justify-content: center; text-align: center;">
        <div style="padding: 24px;">
          <svg style="width: 48px; height: 48px; color: var(--orange); margin-bottom: 16px;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"></polygon><line x1="9" y1="3" x2="9" y2="18"></line><line x1="15" y1="6" x2="15" y2="21"></line></svg>
          <h3 style="margin: 0 0 8px; color: var(--charcoal);">Ubicación Satelital</h3>
          <p style="font-size: 0.9rem; color: var(--muted); margin-bottom: 16px;">Coordenadas: Lat {branch.address.geo.lat}, Lng {branch.address.geo.lng}</p>
          <a href={branch.mapUrl} target="_blank" rel="noopener noreferrer" class="button alt">Ver Mapa Interactivo</a>
        </div>
      </div>
    </div>
    
    <div style="margin-top: 24px;">
      <a href="/sucursales/" class="back-link">&larr; Volver a todas las sucursales</a>
    </div>
  </div>
</InstitutionalLayout>
