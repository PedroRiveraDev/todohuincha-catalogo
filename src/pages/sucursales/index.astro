---
import InstitutionalLayout from '../../layouts/InstitutionalLayout.astro';
import {
  loadBranchesJson,
  loadCompanyJson,
} from '../../lib/seo/loadCompanyJson.ts';
import { buildBreadcrumbList, buildWebPage } from '../../lib/seo/jsonld.ts';
import { svg } from '../../lib/icons.ts';

const company = loadCompanyJson();
const branches = loadBranchesJson();
const pageUrl = new URL('/sucursales/', company.url).toString();

const crumb = buildBreadcrumbList({
  items: [
    { name: 'Inicio', item: company.url },
    { name: 'Sucursales', item: pageUrl },
  ],
});

const pageNode = buildWebPage({
  url: pageUrl,
  name: 'Sucursales | Comercializadora Todo Huincha',
  description: 'Nuestras sucursales en Temuco, Constitución y Puerto Montt. Horarios, direcciones y contacto.',
  inLanguage: 'es-CL',
  isPartOf: 'SITE',
  breadcrumb: crumb.itemListElement[crumb.itemListElement.length - 1].item,
});

// Foto industrial por sucursal (reusamos assets existentes del proyecto).
const branchPhotos: Record<string, string> = {
  temuco: '/hero/taller-maquinaria.jpg',
  constitucion: '/hero/panel-3.jpg',
  'puerto-montt': '/hero/panel-5.jpg',
};
const photoFallback = '/hero/taller.jpg';

// Etiqueta corta para mostrar en el mapa (zona geográfica).
const zoneLabels: Record<string, string> = {
  temuco: 'Zona Sur — Temuco',
  constitucion: 'Zona Central — Constitución',
  'puerto-montt': 'Zona Austral — Puerto Montt',
};
const zoneDescriptions: Record<string, string> = {
  temuco: 'Soporte técnico principal y stock completo.',
  constitucion: 'Especialistas en faenas forestales del Maule.',
  'puerto-montt': 'Cobertura logística para la región de Los Lagos.',
};

// Iframe de Google Maps sin API key (point por sucursal).
const mapEmbed = (lat: number, lng: number) =>
  `https://maps.google.com/maps?q=${lat},${lng}&hl=es&z=6&output=embed`;
---
<InstitutionalLayout
  title="Sucursales | Comercializadora Todo Huincha"
  description="Encuentra tu sucursal más cercana de Todo Huincha en Temuco, Constitución y Puerto Montt. Horarios, dirección y teléfonos."
  pageLevelJsonLd={[pageNode, crumb]}
>
  <!-- HERO -->
  <section class="suc-hero">
    <div class="suc-hero-bg" aria-hidden="true"></div>
    <div class="suc-hero-shade" aria-hidden="true"></div>
    <div class="suc-hero-inner">
      <span class="suc-eyebrow">Red de atención nacional</span>
      <h1>Nuestras sucursales</h1>
      <p class="suc-lede">
        Comercializadora Todo Huincha Ltda. cuenta con sucursales estratégicas para abastecer a la industria, la agricultura y las faenas forestales a lo largo del sur de Chile.
      </p>
    </div>
  </section>

  <!-- GRID DE SUCURSALES -->
  <section class="suc-section">
    <div class="suc-wrap">
      <div class="suc-grid">
        {branches.map((branch) => {
          const photo = branchPhotos[branch.slug] ?? photoFallback;
          const phoneRaw = branch.phone.replace(/\s|\(|\)/g, '');
          return (
            <article class="suc-card">
              <div class="suc-card-photo">
                <img src={photo} alt={`Sucursal ${branch.name}`} loading="lazy" />
                {branch.isHeadquarters && (
                  <span class="suc-card-badge">Casa Matriz</span>
                )}
              </div>
              <div class="suc-card-body">
                <h2>{branch.city}</h2>
                <ul class="suc-card-info">
                  <li>
                    <span class="suc-info-icon" set:html={svg('location')}></span>
                    <span>{branch.address.street}, {branch.address.locality}, {branch.address.region}</span>
                  </li>
                  <li>
                    <span class="suc-info-icon" set:html={svg('call')}></span>
                    <a href={`tel:${phoneRaw}`}>{branch.phone}</a>
                  </li>
                  <li>
                    <span class="suc-info-icon" set:html={svg('schedule')}></span>
                    <span>{branch.hours.replace('Lunes a Viernes', 'Lun - Vie')}</span>
                  </li>
                </ul>
              </div>
              <div class="suc-card-actions">
                <a class="suc-card-btn suc-card-btn--primary" href={branch.mapUrl} target="_blank" rel="noopener noreferrer"><span class="suc-card-btn-icon" set:html={svg('map', 16)}></span>Google Maps</a>
                <a class="suc-card-btn suc-card-btn--icon" href={`/sucursales/${branch.slug}/`} aria-label={`Ver detalles de ${branch.name}`} set:html={svg('info', 18)}></a>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- UBICACIÓN ESTRATÉGICA + MAPA -->
  <section class="suc-section suc-section--soft">
    <div class="suc-wrap">
      <div class="suc-map">
        <div class="suc-map-copy">
          <span class="suc-eyebrow">Cobertura</span>
          <h2 class="suc-h2">Ubicación estratégica</h2>
          <p>Estamos presentes en los núcleos productivos más importantes del sur del país para garantizar tiempos de respuesta mínimos y soporte técnico presencial.</p>
          <ul class="suc-zones">
            {branches.map((branch) => (
              <li class={`suc-zone ${branch.isHeadquarters ? 'suc-zone--active' : ''}`}>
                <p class="suc-zone-name">{zoneLabels[branch.slug] ?? branch.name}</p>
                <p class="suc-zone-desc">{zoneDescriptions[branch.slug] ?? ''}</p>
              </li>
            ))}
          </ul>
        </div>
        <div class="suc-map-frame">
          {branches[0] && (
            <iframe
              title={`Ubicación de ${branches[0].name}`}
              src={mapEmbed(branches[0].address.geo.lat, branches[0].address.geo.lng)}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen
            ></iframe>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="suc-cta">
    <div class="suc-cta-inner">
      <span class="suc-cta-eyebrow">Asesoría técnica</span>
      <h2>¿Necesitas ayuda para elegir tu maquinaria?</h2>
      <p>Nuestros expertos están disponibles en todas las sucursales para ayudarte a elegir la mejor máquina para tu faena.</p>
      <div class="suc-cta-actions">
        <a class="suc-cta-btn suc-cta-btn--primary" href="/contacto"><span class="suc-cta-btn-icon" set:html={svg('phone', 16)}></span>Contactar sucursal</a>
        <a class="suc-cta-btn suc-cta-btn--ghost" href="/catalogo"><span class="suc-cta-btn-icon" set:html={svg('grid', 16)}></span>Ver catálogo</a>
      </div>
    </div>
  </section>
</InstitutionalLayout>

<style is:global>
  /* =========================================================
     Sucursales — Todo Huincha
     Reusa variables del Base layout: --orange, --charcoal,
     --ink, --muted, --surface, --soft, --line, --radius.
     ========================================================= */

  /* HERO */
  .suc-hero{
    position:relative;
    height:540px;
    display:flex;
    align-items:center;
    overflow:hidden;
    background:var(--charcoal);
    border-bottom:1px solid var(--line);
  }
  .suc-hero-bg{
    position:absolute;inset:0;
    background:
      linear-gradient(180deg,rgba(49,62,72,.35) 0%,rgba(49,62,72,.75) 100%),
      url('/hero/taller.jpg') center/cover no-repeat;
    filter:saturate(.85) contrast(1.05);
  }
  .suc-hero-shade{
    position:absolute;inset:0;
    background:linear-gradient(180deg,rgba(249,249,249,0) 0%,rgba(249,249,249,.92) 90%);
  }
  .suc-hero-inner{
    position:relative;
    width:100%;
    max-width:1280px;
    margin:auto;
    padding:clamp(80px,10vw,120px) clamp(20px,5vw,40px);
  }
  .suc-hero h1{
    color:var(--charcoal);
    font-size:clamp(2.6rem,6vw,4.8rem);
    line-height:1.02;letter-spacing:-.035em;
    text-transform:none;
    margin:0 0 18px;font-weight:800;
  }
  .suc-lede{
    color:var(--ink);
    font-size:clamp(1.02rem,1.2vw,1.18rem);
    line-height:1.6;max-width:62ch;margin:0;
  }
  .suc-eyebrow{
    display:inline-block;
    color:var(--orange);
    font-size:.78rem;font-weight:850;letter-spacing:.2em;text-transform:uppercase;
    margin-bottom:14px;
  }

  /* SECCIONES */
  .suc-section{padding:clamp(56px,7vw,96px) 0}
  .suc-section--soft{background:var(--soft);border-top:1px solid var(--line)}
  .suc-wrap{
    max-width:1280px;
    margin:auto;
    padding:0 clamp(20px,5vw,40px);
  }

  /* GRID DE CARDS */
  .suc-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
    gap:28px;
  }
  .suc-card{
    display:flex;flex-direction:column;
    background:var(--surface);
    border:1px solid var(--line);
    border-radius:var(--radius);
    overflow:hidden;
    transition:transform .25s, border-color .25s, box-shadow .25s;
  }
  .suc-card:hover{
    transform:translateY(-4px);
    border-color:var(--orange);
    box-shadow:0 14px 30px rgba(45,25,13,.10);
  }
  .suc-card-photo{
    position:relative;
    height:240px;
    overflow:hidden;
    background:var(--charcoal);
    border-bottom:1px solid var(--line);
  }
  .suc-card-photo img{
    width:100%;height:100%;object-fit:cover;
    transition:transform .5s ease;
  }
  .suc-card:hover .suc-card-photo img{transform:scale(1.05)}
  .suc-card-badge{
    position:absolute;
    top:16px;left:16px;
    background:var(--orange);
    color:#fff;
    font-size:.74rem;font-weight:850;letter-spacing:.12em;
    text-transform:uppercase;
    padding:6px 12px;border-radius:6px;
  }
  .suc-card-body{padding:28px 28px 8px;flex:1 1 auto}
  .suc-card-body h2{
    color:var(--charcoal);
    font-size:1.6rem;font-weight:800;
    letter-spacing:-.01em;margin:0 0 20px;
    transition:color .2s;
  }
  .suc-card:hover .suc-card-body h2{color:var(--orange)}
  .suc-card-info{
    list-style:none;margin:0;padding:0;
    display:flex;flex-direction:column;gap:16px;
  }
  .suc-card-info li{
    display:flex;align-items:flex-start;gap:12px;
    color:var(--muted);font-size:.96rem;line-height:1.5;
  }
  .suc-info-icon{
    flex-shrink:0;
    width:22px;height:22px;
    color:var(--orange);
    display:inline-flex;align-items:center;justify-content:center;
  }
  .suc-card-info a{color:inherit}
  .suc-card-info a:hover{color:var(--orange)}
  .suc-card-actions{
    display:flex;gap:10px;
    padding:24px 28px 28px;
  }
  .suc-card-btn{
    display:inline-flex;align-items:center;justify-content:center;
    gap:8px;
    font-size:.78rem;font-weight:800;letter-spacing:.12em;text-transform:uppercase;
    border-radius:8px;
    padding:12px 18px;
    transition:background .2s, color .2s, border-color .2s;
  }
  .suc-card-btn-icon{
    display:inline-flex;align-items:center;justify-content:center;
    flex-shrink:0;
  }
  .suc-card-btn--primary{
    flex:1 1 auto;
    background:var(--surface);
    color:var(--charcoal);
    border:1px solid var(--line);
  }
  .suc-card-btn--primary:hover{
    background:var(--orange);
    color:#fff;
    border-color:var(--orange);
  }
  .suc-card-btn--icon{
    flex:0 0 auto;
    width:46px;padding:0;
    background:var(--soft);
    color:var(--charcoal);
    border:1px solid transparent;
  }
  .suc-card-btn--icon:hover{
    background:var(--orange);
    color:#fff;
  }

  /* MAPA + COPY */
  .suc-map{
    display:grid;
    grid-template-columns:minmax(0,1fr) minmax(0,2fr);
    gap:clamp(32px,5vw,64px);
    align-items:stretch;
  }
  .suc-map-copy h2{
    color:var(--charcoal);
    font-size:clamp(1.8rem,3.2vw,2.4rem);
    line-height:1.1;letter-spacing:-.03em;
    margin:0 0 16px;font-weight:800;text-transform:none;
  }
  .suc-map-copy > p{
    color:var(--muted);line-height:1.65;margin:0 0 24px;max-width:48ch;
  }
  .suc-zones{
    list-style:none;margin:0;padding:0;
    display:flex;flex-direction:column;gap:14px;
  }
  .suc-zone{
    background:var(--surface);
    border:1px solid var(--line);
    border-left:4px solid var(--line);
    border-radius:8px;
    padding:14px 16px;
    transition:border-color .2s, transform .2s;
  }
  .suc-zone:hover{border-left-color:var(--orange);transform:translateX(2px)}
  .suc-zone--active{border-left-color:var(--orange);box-shadow:0 6px 14px rgba(45,25,13,.06)}
  .suc-zone-name{
    margin:0 0 4px;
    color:var(--charcoal);
    font-size:.92rem;font-weight:800;letter-spacing:.01em;
  }
  .suc-zone-desc{
    margin:0;
    color:var(--muted);
    font-size:.82rem;line-height:1.5;
  }
  .suc-map-frame{
    position:relative;
    min-height:480px;
    background:var(--surface);
    border:1px solid var(--line);
    border-radius:var(--radius);
    overflow:hidden;
  }
  .suc-map-frame iframe{
    position:absolute;inset:0;
    width:100%;height:100%;border:0;
    filter:saturate(.7) contrast(.95);
  }

  /* CTA */
  .suc-cta{
    background:
      radial-gradient(circle at 80% 20%,rgba(251,77,8,.16),transparent 55%),
      linear-gradient(135deg,#1f262e 0%,var(--charcoal) 100%);
    color:#fff;
    padding:clamp(64px,9vw,112px) clamp(20px,5vw,40px);
    text-align:center;
  }
  .suc-cta-inner{max-width:780px;margin:auto}
  .suc-cta-eyebrow{
    display:inline-block;
    color:#ffb18f;
    font-size:.78rem;font-weight:850;letter-spacing:.18em;text-transform:uppercase;
    margin-bottom:14px;
  }
  .suc-cta h2{
    color:#fff;
    font-size:clamp(1.8rem,3.6vw,2.8rem);
    line-height:1.1;letter-spacing:-.025em;
    margin:0 0 16px;font-weight:800;
  }
  .suc-cta p{color:rgba(255,255,255,.78);margin:0 0 30px;line-height:1.6}
  .suc-cta-actions{display:flex;gap:14px;justify-content:center;flex-wrap:wrap}
  .suc-cta-btn{
    display:inline-flex;align-items:center;justify-content:center;
    gap:10px;
    padding:14px 28px;
    font-size:.92rem;font-weight:800;letter-spacing:.12em;text-transform:uppercase;
    border-radius:8px;
    transition:transform .2s, background .2s, color .2s, border-color .2s;
  }
  .suc-cta-btn-icon{
    display:inline-flex;align-items:center;justify-content:center;
    flex-shrink:0;
  }
  .suc-cta-btn--primary{background:var(--orange);color:#fff;border:1px solid var(--orange)}
  .suc-cta-btn--primary:hover{background:var(--orange-deep);transform:translateY(-1px)}
  .suc-cta-btn--ghost{background:transparent;color:#fff;border:2px solid var(--orange)}
  .suc-cta-btn--ghost:hover{background:rgba(251,77,8,.08);border-color:var(--orange)}

  /* Responsive */
  @media (max-width:900px){
    .suc-map{grid-template-columns:1fr;gap:32px}
    .suc-map-frame{min-height:360px}
  }
  @media (max-width:640px){
    .suc-hero{height:420px}
    .suc-card-photo{height:200px}
    .suc-grid{gap:20px}
  }
</style>