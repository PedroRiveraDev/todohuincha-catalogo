---
import InstitutionalLayout from '../../layouts/InstitutionalLayout.astro';
import {
  loadBranchesJson,
  loadCompanyJson,
  loadTeamJson,
} from '../../lib/seo/loadCompanyJson.ts';
import { buildBreadcrumbList, buildWebPage } from '../../lib/seo/jsonld.ts';
import { svg } from '../../lib/icons.ts';

const company = loadCompanyJson();
const branches = loadBranchesJson();
const team = loadTeamJson();
const pageUrl = new URL('/empresa/', company.url).toString();
const crumb = buildBreadcrumbList({
  items: [
    { name: 'Inicio', item: company.url },
    { name: 'Empresa', item: pageUrl },
  ],
});
const pageNode = buildWebPage({
  url: pageUrl,
  name: 'Empresa | Comercializadora Todo Huincha',
  description: company.shortPitch,
  inLanguage: 'es-CL',
  isPartOf: 'SITE',
  breadcrumb: crumb.itemListElement[crumb.itemListElement.length - 1].item,
});

// Métricas coherentes con la realidad de la empresa.
const metrics = [
  { value: '3', label: 'Sucursales en el sur' },
  { value: '30+', label: 'Años de experiencia' },
  { value: '1000+', label: 'Clientes activos' },
  { value: '24/7', label: 'Soporte técnico' },
];

// Pilares derivados de la misión y el tipo de operación.
const pillars = [
  {
    icon: 'precision',
    title: 'Precisión técnica',
    body: 'Cada máquina, consumible y repuesto se evalúa para asegurar el rendimiento que la industria, agricultura y faenas forestales exigen.',
  },
  {
    icon: 'speed',
    title: 'Respuesta ágil',
    body: 'Operamos con la velocidad de la zona sur: tiempos de respuesta cortos y stock disponible para que tu faena no se detenga.',
  },
  {
    icon: 'shield',
    title: 'Calidad certificada',
    body: 'Trabajamos con marcas reconocidas y proveedores validados. Lo que vendemos es lo que probamos todos los días en terreno.',
  },
  {
    icon: 'people',
    title: 'Acompañamiento real',
    body: 'Servicio técnico, asesoría en compra y postventa. Nuestro equipo se comporta como una extensión de tu operación.',
  },
];

// Iconos importados desde el módulo compartido.
---
<InstitutionalLayout
  title="Empresa | Comercializadora Todo Huincha"
  description={company.shortPitch}
  pageLevelJsonLd={[pageNode, crumb]}
>
  <!-- HERO -->
  <section class="emp-hero">
    <div class="emp-hero-bg" aria-hidden="true"></div>
    <div class="emp-hero-shade" aria-hidden="true"></div>
    <div class="emp-hero-inner">
      <div class="emp-hero-copy">
        <span class="emp-eyebrow"><span class="emp-eyebrow-line"></span>Nuestra identidad</span>
        <h1>Resistencia en cada <span class="emp-accent">faena</span></h1>
        <p class="emp-lede">
          En <strong>Comercializadora Todo Huincha</strong> definimos la excelencia industrial a través de soluciones especializadas de maquinaria, consumibles y servicio técnico. Más de tres décadas sosteniendo a la industria, la agricultura y las faenas forestales del sur de Chile.
        </p>
      </div>
    </div>
  </section>

  <!-- NARRATIVA + PILARES (grid 2-col solo en esta sección) -->
  <section class="emp-section">
    <div class="emp-wrap emp-wrap--narrative">
      <div class="emp-narrative">
        <span class="emp-accent-line"></span>
        <span class="emp-eyebrow emp-eyebrow--ink">El referente</span>
        <h2 class="emp-h2">La autoridad en <br/>abastecimiento industrial del sur</h2>
        <p class="emp-body">
          Fundada sobre los principios de precisión técnica y durabilidad industrial, Todo Huincha se ha consolidado como el aliado estratégico de los sectores más exigentes de la Araucanía, el Maule y Los Lagos. No solo vendemos maquinaria: proveemos la tensión que mantiene la producción en marcha.
        </p>
        <div class="emp-metrics">
          {metrics.map((m) => (
            <div class="emp-metric">
              <div class="emp-metric-value">{m.value}</div>
              <div class="emp-metric-label">{m.label}</div>
            </div>
          ))}
        </div>
      </div>
      <div class="emp-pillars">
        {pillars.map((p) => (
          <article class="emp-pillar">
            <span class="emp-pillar-icon" set:html={svg(p.icon)}></span>
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- MISIÓN Y VISIÓN -->
  <section class="emp-section emp-section--soft">
    <div class="emp-wrap emp-wrap--center">
      <div class="emp-mv-head">
        <span class="emp-eyebrow">Misión y visión</span>
        <h2 class="emp-h2">El compromiso que nos mueve</h2>
      </div>
      <div class="emp-mv">
        <article class="emp-mv-card">
          <span class="emp-mv-eyebrow">Misión</span>
          <p class="emp-mv-quote">{company.mission}</p>
        </article>
        <article class="emp-mv-card">
          <span class="emp-mv-eyebrow">Visión</span>
          <p class="emp-mv-quote">{company.vision}</p>
        </article>
      </div>
    </div>
  </section>

  <!-- LÍNEAS DE SERVICIO (BENTO) -->
  <section class="emp-section emp-section--soft">
    <div class="emp-wrap">
      <header class="emp-services-head">
        <div class="emp-services-head-left">
          <span class="emp-eyebrow">Especialidades</span>
          <h2 class="emp-h2">Líneas de servicio</h2>
        </div>
        <p class="emp-services-intro">
          Cubrimos todo el ciclo del equipamiento industrial: venta, asesoría, mantención y repuestos. Una sola empresa, una sola llamada.
        </p>
      </header>

      <div class="emp-bento">
        <article class="emp-bento-card emp-bento-card--lead">
          <div class="emp-bento-bg" aria-hidden="true"></div>
          <div class="emp-bento-shade" aria-hidden="true"></div>
          <div class="emp-bento-body">
            <span class="emp-bento-eyebrow">Soporte técnico</span>
            <h3>Servicio técnico en taller y terreno</h3>
            <p>Diagnóstico, mantención preventiva y correctiva para la maquinaria que comercializamos. Atendemos en nuestras sucursales y nos desplazamos a faena.</p>
          </div>
        </article>

        <article class="emp-bento-card emp-bento-card--audit">
          <span class="emp-bento-icon" set:html={svg('audit')}></span>
          <h3>Asesoría en compra</h3>
          <p>Te ayudamos a elegir la máquina o consumible correcto según tu faena, volumen y presupuesto.</p>
          <a class="emp-bento-link" href="/contacto"><span class="emp-bento-link-icon" set:html={svg('arrow', 16)}></span>Solicitar asesoría</a>
        </article>

        <article class="emp-bento-card emp-bento-card--training">
          <span class="emp-bento-icon" set:html={svg('training')}></span>
          <h3>Capacitación</h3>
          <p>Entrenamiento en uso seguro, mantención básica y mejores prácticas para tu equipo en terreno.</p>
        </article>

        <article class="emp-bento-card emp-bento-card--stock">
          <span class="emp-bento-icon" set:html={svg('stock')}></span>
          <h3>Stock y repuestos</h3>
          <p>Reposición constante de consumibles y repuestos originales para que la operación no se detenga.</p>
        </article>

        <article class="emp-bento-card emp-bento-card--tools">
          <span class="emp-bento-icon" set:html={svg('tools')}></span>
          <h3>Reparación especializada</h3>
          <p>Taller propio con técnicos certificados para sierras huincha, cepilladoras, partidores, motocultivadores y más.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- EQUIPO DIRECTIVO -->
  <section class="emp-section">
    <div class="emp-wrap emp-wrap--center">
      <header class="emp-team-head">
        <span class="emp-eyebrow emp-eyebrow--ink">Dirección</span>
        <h2 class="emp-h2">El equipo directivo</h2>
        <p class="emp-team-intro">Conduciendo la visión de Todo Huincha hacia un sur de Chile más productivo y conectado.</p>
      </header>

      <div class="emp-team">
        {team.map((member) => (
          <article class="emp-member">
            <div class="emp-member-photo">
              {member.photo ? (
                <img src={member.photo} alt={member.name} loading="lazy" />
              ) : (
                <div class="emp-member-initials" aria-hidden="true">
                  {member.name.split(' ').map((part) => part[0]).slice(0, 2).join('')}
                </div>
              )}
            </div>
            <h3>{member.name}</h3>
            <p class="emp-member-role">{member.role}</p>
            {member.bio && (
              <blockquote class="emp-member-bio">
                <p>{member.bio}</p>
              </blockquote>
            )}
            {member.responsibilities.length > 0 && (
              <p class="emp-member-body">{member.responsibilities.join(' · ')}</p>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- COBERTURA -->
  <section class="emp-section emp-section--soft">
    <div class="emp-wrap emp-wrap--center">
      <header class="emp-branches-head">
        <span class="emp-eyebrow">Cobertura</span>
        <h2 class="emp-h2">Llegamos a todo el sur</h2>
        <p>Tres sucursales físicas para que la distancia no sea un problema. Conoce la más cercana a tu faena.</p>
      </header>

      <div class="emp-branches">
        {branches.map((branch) => (
          <a class="emp-branch" href={`/sucursales/${branch.slug}/`}>
            <div class="emp-branch-head">
              <span class="emp-branch-icon" set:html={svg('building')}></span>
              <span class="emp-branch-arrow" set:html={svg('arrow', 18)}></span>
            </div>
            <h3>{branch.name}</h3>
            <p class="emp-branch-loc">{branch.address.locality}, {branch.address.region}</p>
            <p class="emp-branch-addr">{branch.address.street}</p>
            <p class="emp-branch-hours">{branch.hours}</p>
            <span class="emp-branch-link" set:html={`${svg('phone')}<span>${branch.phone}</span>`}></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="emp-cta">
    <div class="emp-cta-inner">
      <h2>¿Listo para equipar tu próxima faena?</h2>
      <p>Cotiza con nosotros. Te respondemos el mismo día con stock real y precios claros.</p>
      <div class="emp-cta-actions">
        <a class="emp-cta-btn emp-cta-btn--primary" href="/contacto"><span class="emp-cta-btn-icon" set:html={svg('quote', 16)}></span>Iniciar una cotización</a>
        <a class="emp-cta-btn emp-cta-btn--ghost" href="/catalogo"><span class="emp-cta-btn-icon" set:html={svg('grid', 16)}></span>Ver catálogo</a>
      </div>
    </div>
  </section>
</InstitutionalLayout>

<style is:global>
  /* =========================================================
     Empresa — sección "Comercializadora Todo Huincha"
     Reusa variables del Base layout: --orange, --charcoal,
     --ink, --muted, --canvas, --surface, --soft, --line, --radius.
     Cada sección maneja su propio grid interno. El grid 2-col
     padre SOLO se aplica a la sección de narrativa + pilares.
     ========================================================= */

  .emp-hero{
    position:relative;
    height:540px;
    display:flex;
    align-items:center;
    overflow:hidden;
    background:var(--charcoal);
  }
  .emp-hero-bg{
    position:absolute;inset:0;
    background:
      linear-gradient(180deg,rgba(49,62,72,.45) 0%,rgba(49,62,72,.65) 100%),
      url('/hero/taller-maquinaria.jpg') center/cover no-repeat;
    filter:saturate(.85) contrast(1.05);
  }
  .emp-hero-shade{
    position:absolute;inset:0;
    background:linear-gradient(90deg,rgba(28,32,38,.92) 0%,rgba(28,32,38,.55) 55%,rgba(28,32,38,.15) 100%);
  }
  .emp-hero-inner{
    position:relative;
    width:100%;
    max-width:1280px;
    margin:auto;
    padding:clamp(80px,10vw,120px) clamp(20px,5vw,40px);
  }
  .emp-hero-copy{max-width:780px}
  .emp-eyebrow{
    display:inline-flex;align-items:center;gap:10px;
    color:var(--orange);
    font-size:.78rem;font-weight:850;letter-spacing:.18em;text-transform:uppercase;
    margin-bottom:18px;
  }
  .emp-eyebrow--ink{color:var(--orange)}
  .emp-eyebrow-line{
    display:inline-block;width:36px;height:2px;background:var(--orange);
  }
  .emp-hero h1{
    color:#fff;
    font-size:clamp(2.4rem,5.4vw,4.6rem);
    line-height:1.02;letter-spacing:-.035em;
    text-transform:uppercase;margin:0 0 22px;
  }
  .emp-accent{color:var(--orange)}
  .emp-lede{
    color:rgba(255,255,255,.82);
    font-size:clamp(1rem,1.2vw,1.18rem);
    line-height:1.6;max-width:62ch;margin:0;
  }
  .emp-lede strong{color:#fff}

  /* Secciones base */
  .emp-section{padding:clamp(64px,8vw,112px) 0}
  .emp-section--soft{background:var(--soft)}
  .emp-wrap{
    max-width:1280px;
    margin:auto;
    padding:0 clamp(20px,5vw,40px);
  }
  .emp-wrap--center{text-align:center}
  .emp-wrap--center .emp-h2,
  .emp-wrap--center .emp-team-intro,
  .emp-wrap--center .emp-branches-head p{margin-left:auto;margin-right:auto}
  .emp-wrap--narrative{
    display:grid;
    grid-template-columns:minmax(0,1fr) minmax(0,1.4fr);
    gap:clamp(40px,6vw,80px);
    align-items:start;
  }
  .emp-accent-line{
    display:block;width:60px;height:4px;background:var(--orange);
    border-radius:2px;margin-bottom:20px;
  }
  .emp-h2{
    color:var(--charcoal);
    font-size:clamp(1.8rem,3.4vw,2.6rem);
    line-height:1.08;letter-spacing:-.03em;
    text-transform:uppercase;margin:0 0 16px;font-weight:800;
  }
  .emp-body{color:var(--muted);line-height:1.65;font-size:1.02rem;max-width:60ch}

  /* Narrativa + Pilares */
  .emp-narrative{display:grid;gap:18px;align-content:start}
  .emp-metrics{
    display:grid;grid-template-columns:repeat(2,minmax(0,1fr));
    gap:24px;margin-top:32px;
    border-top:1px solid var(--line);
    padding-top:28px;
  }
  .emp-metric-value{
    color:var(--orange);
    font-size:clamp(2rem,3vw,2.6rem);
    font-weight:850;letter-spacing:-.04em;line-height:1;
  }
  .emp-metric-label{
    color:var(--charcoal);
    font-size:.78rem;font-weight:800;letter-spacing:.12em;
    text-transform:uppercase;margin-top:8px;
  }

  .emp-pillars{
    display:grid;
    grid-template-columns:repeat(2,minmax(0,1fr));
    gap:18px;
  }
  .emp-pillar{
    background:var(--surface);
    border:1px solid var(--line);
    border-radius:var(--radius);
    padding:28px 26px;
    transition:border-color .25s, transform .25s, box-shadow .25s;
  }
  .emp-pillar:hover{
    border-color:var(--orange);
    transform:translateY(-2px);
    box-shadow:0 16px 32px rgba(251,77,8,.10);
  }
  .emp-pillar-icon{
    display:inline-flex;
    width:44px;height:44px;
    color:var(--orange);
    margin-bottom:14px;
  }
  .emp-pillar h3{
    color:var(--charcoal);
    font-size:1.12rem;font-weight:700;
    margin:0 0 8px;letter-spacing:-.01em;
  }
  .emp-pillar p{color:var(--muted);font-size:.94rem;line-height:1.55;margin:0}

  /* Misión / Visión */
  .emp-mv-head{text-align:center;margin-bottom:48px;max-width:720px;margin-inline:auto}
  .emp-mv-head .emp-h2{margin-top:10px}
  .emp-mv{
    display:grid;
    grid-template-columns:repeat(2,minmax(0,1fr));
    gap:24px;
    text-align:left;
  }
  .emp-mv-card{
    background:var(--surface);
    border:1px solid var(--line);
    border-left:4px solid var(--orange);
    border-radius:var(--radius);
    padding:32px 30px;
    box-shadow:0 8px 24px rgba(45,25,13,.04);
  }
  .emp-mv-eyebrow{
    display:inline-block;
    color:var(--orange);
    font-size:.78rem;font-weight:850;letter-spacing:.18em;text-transform:uppercase;
    margin-bottom:14px;
  }
  .emp-mv-quote{
    color:var(--charcoal);
    font-size:1.08rem;line-height:1.55;margin:0;
  }

  /* Bento servicios */
  .emp-services-head{
    display:grid;
    grid-template-columns:minmax(0,1fr) minmax(0,1fr);
    gap:clamp(24px,4vw,60px);
    align-items:end;
    margin-bottom:48px;
  }
  .emp-services-head-left{min-width:0}
  .emp-services-head .emp-h2{margin-top:10px}
  .emp-services-intro{
    color:var(--muted);line-height:1.6;margin:0;
    text-align:right;
  }
  .emp-bento{
    display:grid;
    grid-template-columns:minmax(0,1fr) minmax(0,1fr) minmax(0,1fr);
    grid-auto-rows:minmax(180px,auto);
    gap:18px;
  }
  .emp-bento-card{
    position:relative;
    overflow:hidden;
    border-radius:var(--radius);
    border:1px solid var(--line);
    padding:28px 26px;
    background:var(--surface);
    display:flex;flex-direction:column;gap:12px;
    transition:transform .35s, box-shadow .35s;
  }
  .emp-bento-card:hover{transform:translateY(-3px);box-shadow:0 18px 36px rgba(45,25,13,.10)}
  .emp-bento-card--lead{
    grid-column:1 / span 2;grid-row:1 / span 2;
    color:#fff;
    padding:0;
    border-color:transparent;
  }
  .emp-bento-card--audit{grid-column:3;grid-row:1}
  .emp-bento-card--training{grid-column:3;grid-row:2}
  .emp-bento-card--stock{grid-column:1 / span 2;grid-row:3}
  .emp-bento-card--tools{grid-column:3;grid-row:3}
  .emp-bento-bg{
    position:absolute;inset:0;
    background:
      linear-gradient(180deg,rgba(28,32,38,.55) 0%,rgba(28,32,38,.85) 100%),
      url('/hero/taller.jpg') center/cover no-repeat;
  }
  .emp-bento-shade{position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,0) 40%,rgba(0,0,0,.55) 100%)}
  .emp-bento-body{
    position:relative;z-index:1;
    margin-top:auto;padding:36px 32px;
    display:flex;flex-direction:column;gap:12px;
  }
  .emp-bento-eyebrow{
    color:#ffb18f;
    font-size:.74rem;font-weight:850;letter-spacing:.18em;text-transform:uppercase;
  }
  .emp-bento-card--lead h3{
    color:#fff;
    font-size:clamp(1.4rem,2.4vw,1.9rem);
    text-transform:uppercase;letter-spacing:-.02em;
    margin:0;line-height:1.1;
  }
  .emp-bento-card--lead p{color:rgba(255,255,255,.85);margin:0;line-height:1.55;max-width:38ch}
  .emp-bento-card--audit{
    grid-column:span 2;
    background:var(--charcoal);
    color:#fff;
    border-color:transparent;
  }
  .emp-bento-card--audit h3{color:#fff;font-size:1.15rem;text-transform:uppercase;margin:0;letter-spacing:-.01em}
  .emp-bento-card--audit p{color:rgba(255,255,255,.78);margin:0;font-size:.95rem;line-height:1.5}
  .emp-bento-card--training{background:var(--surface)}
  .emp-bento-card--training h3,.emp-bento-card--tools h3{color:var(--charcoal);font-size:1.05rem;text-transform:uppercase;margin:0;letter-spacing:-.01em}
  .emp-bento-card--training p,.emp-bento-card--tools p{color:var(--muted);margin:0;font-size:.92rem;line-height:1.5}
  .emp-bento-card--stock{
    background:var(--orange);
    color:#fff;
    border-color:transparent;
  }
  .emp-bento-card--stock h3{color:#fff;font-size:1.05rem;text-transform:uppercase;margin:0;letter-spacing:-.01em}
  .emp-bento-card--stock p{color:rgba(255,255,255,.92);margin:0;font-size:.92rem;line-height:1.5}
  .emp-bento-icon{display:inline-flex;width:36px;height:36px;color:var(--orange)}
  .emp-bento-card--audit .emp-bento-icon,.emp-bento-card--lead .emp-bento-icon{color:#ffb18f}
  .emp-bento-card--stock .emp-bento-icon{color:#fff}
  .emp-bento-link{
    margin-top:auto;
    display:inline-flex;align-items:center;gap:10px;
    color:var(--orange);font-weight:800;font-size:.82rem;
    letter-spacing:.14em;text-transform:uppercase;
    transition:transform .2s;
  }
  .emp-bento-link:hover{transform:translateX(3px)}
  .emp-bento-link-icon{
    display:inline-flex;align-items:center;justify-content:center;
    flex-shrink:0;
  }
  .emp-bento-card--audit .emp-bento-link{color:#ffb18f}

  /* Equipo directivo */
  .emp-team-head{margin-bottom:48px;max-width:760px;margin-inline:auto}
  .emp-team-head .emp-h2{margin-top:8px}
  .emp-team-intro{color:var(--muted);margin:12px auto 0;max-width:60ch;line-height:1.6}
  .emp-team{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
    gap:32px;
    max-width:1080px;margin:auto;
  }
  .emp-member{
    background:var(--surface);
    border:1px solid var(--line);
    border-top:4px solid var(--orange);
    border-radius:var(--radius);
    padding:32px 28px;
    text-align:center;
    transition:transform .3s, box-shadow .3s;
  }
  .emp-member:hover{transform:translateY(-3px);box-shadow:0 18px 36px rgba(45,25,13,.10)}
  .emp-member-photo{
    width:140px;height:140px;
    border-radius:50%;
    margin:0 auto 22px;
    background:linear-gradient(135deg,var(--charcoal) 0%,#1f262e 100%);
    display:flex;align-items:center;justify-content:center;
    overflow:hidden;
    box-shadow:0 10px 26px rgba(45,25,13,.18);
  }
  .emp-member-photo img{
    width:100%;height:100%;
    object-fit:cover;
    object-position:center;
  }
  .emp-member-initials{
    color:#fff;
