---
import Base from '../layouts/Base.astro';
import FreshAstroRedirect from '../components/FreshAstroRedirect.astro';
---
<Base
  title="Redirigiendo a Mision y vision | Todo Huincha"
  description="Redireccion a la mision y vision de Comercializadora Todo Huincha Ltda."
  canonical="https://todohuincha.com/empresa/mision-vision/"
  noIndex={true}
>
  <FreshAstroRedirect target="/empresa/mision-vision/" />
  <section class="wrap">
    <span class="eyebrow">Redireccion</span>
    <h1>Redirigiendo a mision y vision...</h1>
    <p>Si no es redirigido automaticamente, <a href="/empresa/mision-vision/">lea nuestra mision y vision</a>.</p>
  </section>
</Base>