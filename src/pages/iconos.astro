<style>
  /* HERO */
  .ico-hero{
    background:var(--charcoal);
    color:#fff;
    padding:clamp(72px,10vw,120px) clamp(20px,5vw,40px) clamp(48px,7vw,80px);
    text-align:center;
  }
  .ico-hero-inner{max-width:780px;margin:auto}
  .ico-eyebrow{
    display:inline-block;
    color:#ffb18f;
    font-size:.78rem;font-weight:850;letter-spacing:.2em;text-transform:uppercase;
    margin-bottom:14px;
  }
  .ico-hero h1{
    color:#fff;
    font-size:clamp(2.4rem,5.4vw,4rem);
    line-height:1.05;letter-spacing:-.03em;
    margin:0 0 16px;font-weight:800;
  }
  .ico-lede{
    color:rgba(255,255,255,.8);
    font-size:clamp(1rem,1.15vw,1.1rem);
    line-height:1.6;margin:0;
  }

  /* SECCIONES */
  .ico-section{padding:clamp(64px,8vw,104px) 0}
  .ico-section--soft{background:var(--soft)}
  .ico-wrap{max-width:1280px;margin:auto;padding:0 clamp(20px,5vw,40px)}
  .ico-head{text-align:center;margin-bottom:48px;max-width:780px;margin-inline:auto}
  .ico-head h2{
    color:var(--charcoal);
    font-size:clamp(1.6rem,2.8vw,2.2rem);
    line-height:1.1;letter-spacing:-.025em;
    margin:10px 0 14px;font-weight:800;
  }
  .ico-head p{color:var(--muted);line-height:1.6;margin:0}

  /* GRID DE ICONOS */
  .ico-grid{
    display:grid;
    grid-template-columns:repeat(auto-fill,minmax(200px,1fr));
    gap:18px;
  }
  .ico-card{
    background:var(--surface);
    border:1px solid var(--line);
    border-radius:var(--radius);
    padding:24px 22px;
    text-align:center;
    transition:border-color .2s, transform .2s, box-shadow .2s;
  }
  .ico-card:hover{
    border-color:var(--orange);
    transform:translateY(-2px);
    box-shadow:0 12px 26px rgba(45,25,13,.08);
  }
  .ico-card--alt{
    background:#fff;
    border-style:dashed;
  }
  .ico-card-icon{
    display:inline-flex;
    width:56px;height:56px;
    color:var(--orange);
    background:var(--soft);
    border-radius:14px;
    align-items:center;justify-content:center;
    margin-bottom:14px;
  }
  .ico-card--alt .ico-card-icon{color:var(--charcoal);background:var(--soft)}
  .ico-card h3{
    color:var(--charcoal);
    font-size:.92rem;font-weight:800;
    margin:0 0 6px;
    font-family:ui-monospace,SFMono-Regular,Menlo,monospace;
  }
  .ico-card-use{
    color:var(--muted);
    font-size:.78rem;line-height:1.4;
    margin:0 0 14px;min-height:2.4em;
  }
  .ico-card-sizes{
    display:flex;justify-content:center;align-items:center;gap:14px;
    color:var(--charcoal);
    padding-top:14px;
    border-top:1px solid var(--line);
  }
  .ico-size-chip{
    display:inline-flex;align-items:center;justify-content:center;
    color:var(--charcoal);
  }

  /* COMPARATIVA */
  .ico-compare{
    display:grid;
    grid-template-columns:1fr;
    gap:18px;
  }
  .ico-compare-row{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:16px;
    background:var(--surface);
    border:1px solid var(--line);
    border-radius:var(--radius);
    padding:18px;
  }
  .ico-compare-cell{
    display:flex;flex-direction:column;align-items:center;gap:10px;
    padding:20px 16px;
    background:var(--canvas);
    border-radius:8px;
  }
  .ico-compare-cell--alt{
    background:rgba(251,77,8,.05);
    border:1px dashed var(--orange);
  }
  .ico-compare-label{
    font-size:.7rem;font-weight:800;letter-spacing:.16em;text-transform:uppercase;
    color:var(--muted);
  }
  .ico-compare-cell--alt .ico-compare-label{color:var(--orange)}
  .ico-compare-icon{
    display:inline-flex;align-items:center;justify-content:center;
    color:var(--charcoal);
    width:64px;height:64px;
  }
  .ico-compare-cell--alt .ico-compare-icon{color:var(--orange)}
  .ico-compare-name{
    font-family:ui-monospace,SFMono-Regular,Menlo,monospace;
    font-size:.82rem;font-weight:700;
    color:var(--charcoal);
  }

  /* TONOS */
  .ico-tones{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:18px;
  }
  .ico-tone-card{
    background:var(--surface);
    border:1px solid var(--line);
    border-radius:var(--radius);
    padding:24px;
    display:flex;flex-direction:column;gap:14px;
  }
  .ico-tone-name{
    font-size:.78rem;font-weight:800;letter-spacing:.14em;text-transform:uppercase;
  }
  .ico-tone-swatch{
    display:block;
    width:100%;height:4px;border-radius:2px;
    margin:6px 0 4px;
  }
  .ico-tone-icons{
    display:flex;flex-wrap:wrap;gap:14px;
  }
  .ico-tone-icon{
    display:inline-flex;align-items:center;justify-content:center;
    width:40px;height:40px;
    background:rgba(255,255,255,.5);
    border-radius:8px;
  }

  /* CTA */
  .ico-cta{
    background:
      radial-gradient(circle at 80% 20%,rgba(251,77,8,.16),transparent 55%),
      linear-gradient(135deg,#1f262e 0%,var(--charcoal) 100%);
    color:#fff;
    padding:clamp(64px,9vw,112px) clamp(20px,5vw,40px);
    text-align:center;
  }
  .ico-cta-inner{max-width:780px;margin:auto}
  .ico-cta h2{
    color:#fff;
    font-size:clamp(1.8rem,3.4vw,2.6rem);
    line-height:1.1;letter-spacing:-.025em;
    margin:0 0 14px;font-weight:800;
  }
  .ico-cta p{color:rgba(255,255,255,.78);margin:0 0 30px;line-height:1.6}
  .ico-cta-actions{display:flex;gap:14px;justify-content:center;flex-wrap:wrap}
  .ico-cta-btn{
    display:inline-flex;align-items:center;justify-content:center;
    padding:14px 26px;
    font-size:.88rem;font-weight:800;letter-spacing:.12em;text-transform:uppercase;
    border-radius:8px;
    transition:transform .2s, background .2s, color .2s, border-color .2s;
  }
  .ico-cta-btn--primary{background:var(--orange);color:#fff;border:1px solid var(--orange)}
  .ico-cta-btn--primary:hover{background:var(--orange-deep);transform:translateY(-1px)}
  .ico-cta-btn--ghost{background:transparent;color:#fff;border:2px solid var(--orange)}
  .ico-cta-btn--ghost:hover{background:rgba(251,77,8,.08)}

  @media (max-width:640px){
    .ico-compare-row{grid-template-columns:1fr}
  }

  /* F — DECISIÓN */
  .ico-decision{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
    gap:20px;
    max-width:980px;margin:auto;
  }
  .ico-decision-card{
    background:var(--surface);
    border:1px solid var(--line);
    border-radius:var(--radius);
    padding:28px 26px;
    position:relative;
  }
  .ico-decision-card--yes{border-top:4px solid var(--orange)}
  .ico-decision-tag{
    display:inline-block;
    background:var(--orange);
    color:#fff;
    font-size:.72rem;font-weight:850;letter-spacing:.14em;text-transform:uppercase;
    padding:4px 10px;border-radius:6px;
    margin-bottom:14px;
  }
  .ico-decision-card h3{
    color:var(--charcoal);
    font-size:1.25rem;font-weight:800;
    margin:0 0 10px;
  }
  .ico-decision-card p{
    color:var(--muted);
    font-size:.92rem;line-height:1.55;
    margin:0 0 14px;
  }
  .ico-decision-card p code{
    background:var(--soft);
    color:var(--charcoal);
    font-family:ui-monospace,SFMono-Regular,Menlo,monospace;
    font-size:.85em;
    padding:1px 6px;border-radius:4px;
  }
  .ico-decision-where{
    display:block;
    color:var(--charcoal);
    font-size:.78rem;font-weight:700;letter-spacing:.04em;
    padding-top:12px;border-top:1px solid var(--line);
  }

  /* H — PLAN EN BOTONES Y CARDS */
  .ico-h-sub{
    color:var(--charcoal);
    font-size:1.05rem;font-weight:800;
    letter-spacing:-.005em;
    margin:48px 0 18px;
  }
  .ico-h-sub:first-of-type{margin-top:8px}

  /* H1 — Demo cards (icono top-right) */
  .ico-demo-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
    gap:18px;
  }
  .ico-demo-card{
    position:relative;
    background:var(--surface);
    border:1px solid var(--line);
    border-radius:var(--radius);
    padding:28px 26px;
    transition:border-color .2s, transform .2s;
  }
  .ico-demo-card:hover{border-color:var(--orange);transform:translateY(-2px)}
  .ico-demo-card-icon{
    position:absolute;
    top:18px;right:18px;
    width:38px;height:38px;
    display:inline-flex;align-items:center;justify-content:center;
    background:var(--soft);
    color:var(--orange);
    border-radius:10px;
  }
  .ico-demo-card h4{
    color:var(--charcoal);
    font-size:1.05rem;font-weight:800;
    margin:0 0 6px;padding-right:48px;
  }
  .ico-demo-meta{
    color:var(--orange);
    font-size:.7rem;font-weight:800;letter-spacing:.14em;text-transform:uppercase;
    margin:0 0 10px;padding-right:48px;
  }
  .ico-demo-card p:not(.ico-demo-meta){
    color:var(--muted);
    font-size:.85rem;line-height:1.45;margin:0 0 4px;
  }

  /* H2 — Demo buttons (icono a la izquierda) */
  .ico-demo-buttons{
    display:flex;flex-wrap:wrap;gap:12px;
